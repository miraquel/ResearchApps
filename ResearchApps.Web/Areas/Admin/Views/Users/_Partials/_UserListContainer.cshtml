@using ResearchApps.Common.Constants
@using ResearchApps.Web.Areas.Admin.Controllers
@model UsersController.UserListVm

<table class="table table-bordered table-hover align-middle mb-0" style="width: 100%;">
    <thead class="table-light">
    <tr>
        <th class="sortable-header" style="min-width: 200px; cursor: pointer;"
            @@click="sort('UserName')" data-column="UserName">
            <div class="d-flex align-items-center">
                <span>User</span>
                <template x-if="sortBy === 'UserName'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="min-width: 200px; cursor: pointer;"
            @@click="sort('Email')" data-column="Email">
            <div class="d-flex align-items-center">
                <span>Email</span>
                <template x-if="sortBy === 'Email'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th style="min-width: 120px;">Role</th>
        <th style="width: 100px;">Status</th>
        <th class="text-center" style="width: 160px;">Actions</th>
    </tr>
    </thead>
    <tbody id="user-table-body">
        @await Html.PartialAsync("_Partials/_UserListPartial", Model)
    </tbody>
    <tfoot class="table-light">
    <tr>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search username..."
                   x-model="filters.UserName" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search email..."
                   x-model="filters.Email" @@input.debounce.500ms="fetchList()">
        </td>
        <td></td>
        <td></td>
        <td class="text-center">
            <button type="button" class="btn btn-sm btn-outline-secondary"
                    @@click="clearFilters()" title="Clear All Filters">
                <i class="ri-filter-off-line"></i>
            </button>
        </td>
    </tr>
    </tfoot>
</table>

<div class="mt-3">
    @await Html.PartialAsync("_Partials/_UserPaginationPartial", Model)
</div>

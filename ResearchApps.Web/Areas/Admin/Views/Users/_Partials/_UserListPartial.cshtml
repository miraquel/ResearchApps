@using ResearchApps.Common.Constants
@using ResearchApps.Web.Areas.Admin.Controllers
@model UsersController.UserListVm

@if (Model.Items.Any())
{
    foreach (var item in Model.Items)
    {
        var initials = ((item.FirstName.Length > 0 ? item.FirstName[..1] : "") + (item.LastName.Length > 0 ? item.LastName[..1] : "")).Trim();
        var fullName = $"{item.FirstName} {item.LastName}".Trim();
        <tr>
            <td>
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <div class="avatar-xs">
                            <span class="avatar-title rounded-circle bg-primary-subtle text-primary">@initials</span>
                        </div>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="fs-14 mb-0">
                            <a href="/Admin/Users/Details/@item.Id" class="text-body">@fullName</a>
                        </h5>
                        <p class="text-muted mb-0">@item.UserName</p>
                    </div>
                </div>
            </td>
            <td>@item.Email</td>
            <td>
                <span class="badge bg-primary-subtle text-primary">@(string.IsNullOrEmpty(item.Roles) ? "No Role" : item.Roles)</span>
            </td>
            <td>
                @if (item.Active)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-danger">Inactive</span>
                }
            </td>
            <td class="text-center">
                <div class="hstack gap-2 justify-content-center">
                    @if (User.HasClaim("permission", PermissionConstants.Users.Edit))
                    {
                        <a href="/Admin/Users/Edit/@item.Id" class="btn btn-sm btn-soft-info" title="Edit">
                            <i class="ri-pencil-fill align-bottom"></i>
                        </a>
                    }
                    @if (User.HasClaim("permission", PermissionConstants.Users.UserRoles))
                    {
                        <a href="/Admin/Users/UserRoles?userId=@item.Id" class="btn btn-sm btn-soft-primary" title="Assign Roles">
                            <i class="ri-user-settings-line align-bottom"></i>
                        </a>
                    }
                    @if (User.HasClaim("permission", PermissionConstants.Users.ChangePassword))
                    {
                        <a href="/Admin/Users/ChangePassword/@item.Id" class="btn btn-sm btn-soft-warning" title="Change Password">
                            <i class="ri-lock-password-line align-bottom"></i>
                        </a>
                    }
                    @if (User.HasClaim("permission", PermissionConstants.Users.Suspend))
                    {
                        <a href="/Admin/Users/Suspend/@item.Id" class="btn btn-sm btn-soft-danger" title="Suspend">
                            <i class="ri-pause-circle-line align-bottom"></i>
                        </a>
                    }
                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="5" class="text-center text-muted py-4">
            <i class="ri-inbox-line fs-2"></i>
            <p class="mb-0 mt-2">No users found</p>
        </td>
    </tr>
}

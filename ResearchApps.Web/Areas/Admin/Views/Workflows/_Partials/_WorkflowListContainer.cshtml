@model ResearchApps.Service.Vm.Common.PagedListVm<ResearchApps.Service.Vm.WfFormVm>

<table class="table table-bordered table-hover align-middle mb-0" style="width: 100%;">
    <thead class="table-light">
    <tr>
        <th class="sortable-header" style="width: 80px; cursor: pointer;"
            @@click="sort('WfFormId')" data-column="WfFormId">
            <div class="d-flex align-items-center justify-content-center">
                <span>ID</span>
                <template x-if="sortBy === 'WfFormId'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="min-width: 200px; cursor: pointer;"
            @@click="sort('FormName')" data-column="FormName">
            <div class="d-flex align-items-center">
                <span>Form Name</span>
                <template x-if="sortBy === 'FormName'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="width: 150px; cursor: pointer;"
            @@click="sort('Initial')" data-column="Initial">
            <div class="d-flex align-items-center justify-content-center">
                <span>Initial</span>
                <template x-if="sortBy === 'Initial'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="text-center" style="width: 80px;">Actions</th>
    </tr>
    </thead>
    <tbody id="workflow-table-body">
        @await Html.PartialAsync("_Partials/_WorkflowListPartial", Model)
    </tbody>
    <tfoot class="table-light">
    <tr>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="ID..."
                   x-model="filters.WfFormId" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search form name..."
                   x-model="filters.FormName" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search initial..."
                   x-model="filters.Initial" @@input.debounce.500ms="fetchList()">
        </td>
        <td class="text-center">
            <button type="button" class="btn btn-sm btn-outline-secondary"
                    @@click="clearFilters()" title="Clear All Filters">
                <i class="ri-filter-off-line"></i>
            </button>
        </td>
    </tr>
    </tfoot>
</table>

<div class="mt-3">
    @await Html.PartialAsync("_Partials/_WorkflowPaginationPartial", Model)
</div>

@using ResearchApps.Common.Constants
@{
    ViewBag.Title = "Role Management";
    ViewBag.pTitle = "Role Management";
    Layout = "_Layout";
}

@Html.AntiForgeryToken()

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div x-data="roleIndex()" x-init="init()">
    <div class="card">
        <div class="card-header">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-soft-secondary" @@click="fetchList()" title="Refresh">
                            <i class="ri-refresh-line" :class="{ 'spin': isLoading }"></i>
                        </button>
                        <button type="button" class="btn btn-soft-warning" @@click="clearFilters()" title="Clear All Filters">
                            <i class="ri-filter-off-line me-1"></i> Clear Filters
                        </button>
                        <div x-show.important="isLoading" class="d-flex align-items-center text-muted" x-cloak>
                            <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <small>Loading...</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 text-end">
                    @if (User.HasClaim("permission", PermissionConstants.Roles.Create))
                    {
                        <a href="@Url.Action("Create", "Roles", new { Area = "Admin" })" class="btn btn-primary">
                            <i class="ri-add-line align-bottom me-1"></i> Create New Role
                        </a>
                    }
                </div>
            </div>
        </div>
        <div class="card-body">
            <div id="role-list-container">
                <div class="text-center py-5 row justify-content-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span class="mt-3 text-muted">Loading...</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/roles/role-index.js"></script>
}

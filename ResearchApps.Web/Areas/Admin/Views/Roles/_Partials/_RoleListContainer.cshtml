@using ResearchApps.Common.Constants
@using ResearchApps.Web.Areas.Admin.Controllers
@model RolesController.RoleListVm

<table class="table table-bordered table-hover align-middle mb-0" style="width: 100%;">
    <thead class="table-light">
    <tr>
        <th class="sortable-header" style="min-width: 200px; cursor: pointer;"
            @@click="sort('Name')" data-column="Name">
            <div class="d-flex align-items-center">
                <span>Role Name</span>
                <template x-if="sortBy === 'Name'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="min-width: 250px; cursor: pointer;"
            @@click="sort('Description')" data-column="Description">
            <div class="d-flex align-items-center">
                <span>Description</span>
                <template x-if="sortBy === 'Description'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th style="min-width: 200px;">Role Id</th>
        <th class="text-center" style="width: 100px;">Actions</th>
    </tr>
    </thead>
    <tbody id="role-table-body">
        @await Html.PartialAsync("_Partials/_RoleListPartial", Model)
    </tbody>
    <tfoot class="table-light">
    <tr>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search role name..."
                   x-model="filters.Name" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search description..."
                   x-model="filters.Description" @@input.debounce.500ms="fetchList()">
        </td>
        <td></td>
        <td class="text-center">
            <button type="button" class="btn btn-sm btn-outline-secondary"
                    @@click="clearFilters()" title="Clear All Filters">
                <i class="ri-filter-off-line"></i>
            </button>
        </td>
    </tr>
    </tfoot>
</table>

<div class="mt-3">
    @await Html.PartialAsync("_Partials/_RolePaginationPartial", Model)
</div>

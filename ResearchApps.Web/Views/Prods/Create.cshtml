@model ResearchApps.Service.Vm.ProdVm

@{
    ViewBag.Title = "Create Production Order";
    ViewBag.pTitle = "Create Production Order";
    Layout = "_Layout";
}

<div x-data="prodCreateForm()" x-init="init()">
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Create New Production Order</h5>
                </div>
                <div class="card-body">
                    <form id="prod-form" method="post" action="/Prods/Create">
                        @Html.AntiForgeryToken()
                        
                        <!-- Validation Summary -->
                        <div id="validation-summary" x-show="Object.keys(errors).length > 0" x-cloak>
                            <div class="alert alert-danger">
                                <template x-for="(error, field) in errors" :key="field">
                                    <div x-text="error"></div>
                                </template>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label for="ProdDate" class="form-label">Production Date <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <input type="text" 
                                           id="ProdDate" 
                                           name="ProdDate"
                                           class="form-control"
                                           x-ref="prodDatePicker"
                                           data-flatpickr
                                           :class="{ 'is-invalid': errors.ProdDate }"
                                           required />
                                    <span class="input-group-text"><i class="ri-calendar-line"></i></span>
                                </div>
                                <div class="invalid-feedback" x-show="errors.ProdDate" x-text="errors.ProdDate"></div>
                            </div>
                            <div class="col-md-4">
                                <label for="CustomerId" class="form-label">Customer <span class="text-danger">*</span></label>
                                <select class="form-control form-select"
                                        id="CustomerId" 
                                        name="CustomerId"
                                        x-ref="customerSelect"
                                        data-tomselect
                                        data-url="/api/Customers/cbo"
                                        :class="{ 'is-invalid': errors.CustomerId }"
                                        required>
                                    <option value="">Select Customer</option>
                                </select>
                                <div class="invalid-feedback" x-show="errors.CustomerId" x-text="errors.CustomerId"></div>
                            </div>
                            <div class="col-md-4">
                                <label for="ItemId" class="form-label">Item <span class="text-danger">*</span></label>
                                <select class="form-control form-select"
                                        id="ItemId" 
                                        name="ItemId"
                                        x-ref="itemSelect"
                                        data-tomselect
                                        data-url="/api/Items/cbo"
                                        :class="{ 'is-invalid': errors.ItemId }"
                                        required>
                                    <option value="">Select Item</option>
                                </select>
                                <div class="invalid-feedback" x-show="errors.ItemId" x-text="errors.ItemId"></div>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label for="PlanQty" class="form-label">Planned Quantity <span class="text-danger">*</span></label>
                                <input type="text" 
                                       id="PlanQty" 
                                       name="PlanQty"
                                       class="form-control text-end"
                                       placeholder="Enter quantity"
                                       x-mask:dynamic="$money($input, '.', ',')"
                                       :class="{ 'is-invalid': errors.PlanQty }"
                                       required />
                                <div class="invalid-feedback" x-show="errors.PlanQty" x-text="errors.PlanQty"></div>
                            </div>
                            <div class="col-md-8">
                                <label for="Notes" class="form-label">Notes (Optional)</label>
                                <textarea id="Notes"
                                          name="Notes"
                                          class="form-control" 
                                          rows="1" 
                                          placeholder="Enter notes (optional)"
                                          maxlength="100"
                                          x-model="form.notes"></textarea>
                            </div>
                        </div>
                        
                        <div class="form-group d-flex gap-2">
                            <button type="submit" 
                                    class="btn btn-primary"
                                    :disabled="isSubmitting"
                                    @@click.prevent="confirmCreate()">
                                <span x-show="!isSubmitting">
                                    <i class="ri-save-line me-1"></i> Save
                                </span>
                                <span x-show="isSubmitting" x-cloak>
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    Creating...
                                </span>
                            </button>
                            <a href="/Prods" class="btn btn-secondary">
                                <i class="ri-arrow-left-line me-1"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Confirmation Modal (Optional) -->
    <div class="modal fade" 
         :class="{ 'show d-block': showConfirmModal }"
         x-show="showConfirmModal"
         x-cloak
         tabindex="-1"
         @@click.self="showConfirmModal = false"
         @@keydown.escape.window="showConfirmModal = false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Create</h5>
                    <button type="button" class="btn-close" @@click="showConfirmModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to create this production order?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="showConfirmModal = false">Cancel</button>
                    <button type="button" class="btn btn-primary" @@click="proceedSubmit()">
                        <i class="ri-check-line me-1"></i> Confirm
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show" x-show="showConfirmModal" x-cloak></div>
</div>

@section scripts {
    <script src="~/js/prods/prod-create.js"></script>
}


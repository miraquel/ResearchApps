@using ResearchApps.Common.Constants
@model ResearchApps.Service.Vm.ProdVm

@{
    ViewBag.Title = "Production Details";
    Layout = "_Layout";
}

<div class="card mt-3">
    <div class="card-header">
        <div class="row align-items-center mb-4">
            <div class="col">
                <h4 class="card-title mb-0">Production Details</h4>
            </div>
            <div class="col-auto">
                @if (User.HasClaim("permission", PermissionConstants.Prods.Edit))
                {
                    <a href="@Url.Action("Edit", "Prods", new { id = Model.RecId })" class="btn btn-sm btn-success me-2">
                        <i class="ri-edit-line"></i> Edit
                    </a>
                }
                @if (User.HasClaim("permission", PermissionConstants.Prods.Delete))
                {
                    <a href="@Url.Action("Delete", "Prods", new { id = Model.RecId })" class="btn btn-sm btn-danger">
                        <i class="ri-delete-bin-line"></i> Delete
                    </a>
                }
            </div>
        </div>
        <div class="row">
            <div class="col">
                <ul class="nav nav-tabs-custom rounded card-header-tabs border-bottom-0" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" data-bs-toggle="tab" href="#overview">Overview</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" data-bs-toggle="tab" href="#results">Results</a>
                    </li>
                    @if (User.HasClaim("permission", PermissionConstants.Bpbs.Index))
                    {
                        <li class="nav-item" role="presentation">
                            <a class="nav-link" data-bs-toggle="tab" href="#bpb">Material Withdrawals (BPB)</a>
                        </li>
                    }
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" data-bs-toggle="tab" href="#log">Log</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="tab-content">
            <div class="tab-pane active" id="overview" role="tabpanel">
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ProdId)</strong></div>
                    <div class="col-9">@Model.ProdId</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ProdDate)</strong></div>
                    <div class="col-9">@Model.ProdDate.ToString("dd MMM yyyy")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.CustomerName)</strong></div>
                    <div class="col-9">@Model.CustomerName</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ItemName)</strong></div>
                    <div class="col-9">@Model.ItemName</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.UnitName)</strong></div>
                    <div class="col-9">@Model.UnitName</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.PlanQty)</strong></div>
                    <div class="col-9">@Model.PlanQty.ToString("N2")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.Notes)</strong></div>
                    <div class="col-9">@Model.Notes</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ProdStatusName)</strong></div>
                    <div class="col-9">@Html.Raw(Model.ProdStatusName)</div>
                </div>
            </div>
            <div class="tab-pane" id="results" role="tabpanel">
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ResultQty)</strong></div>
                    <div class="col-9">@Model.ResultQty.ToString("N2")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ResultValue)</strong></div>
                    <div class="col-9">@Model.ResultValue.ToString("N0")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.CostPrice)</strong></div>
                    <div class="col-9">@Model.CostPrice.ToString("N0")</div>
                </div>
            </div>
            @if (User.HasClaim("permission", PermissionConstants.Bpbs.Index))
            {
                <div class="tab-pane" id="bpb" role="tabpanel">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0">Material Withdrawals (BPB) for this Production Order</h6>
                        @if (User.HasClaim("permission", PermissionConstants.Bpbs.Create))
                        {
                            <a href="/Bpbs/Create?prodId=@Model.ProdId" class="btn btn-sm btn-success">
                                <i class="ri-add-line me-1"></i> New BPB
                            </a>
                        }
                    </div>
                    <div id="bpbListContainer" 
                         hx-get="/Bpbs/ListByProd?prodId=@Model.ProdId" 
                         hx-trigger="load" 
                         hx-swap="innerHTML">
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
            <div class="tab-pane" id="log" role="tabpanel">
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.CreatedDate)</strong></div>
                    <div class="col-9">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm:ss")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.CreatedBy)</strong></div>
                    <div class="col-9">@Model.CreatedBy</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ModifiedDate)</strong></div>
                    <div class="col-9">@Model.ModifiedDate.ToString("dd MMM yyyy HH:mm:ss")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ModifiedBy)</strong></div>
                    <div class="col-9">@Model.ModifiedBy</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="text-end mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

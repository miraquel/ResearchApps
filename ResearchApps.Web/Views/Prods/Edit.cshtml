@model ResearchApps.Service.Vm.ProdVm

@{
    ViewBag.Title = "Edit Production Order";
    ViewBag.pTitle = $"Edit Production Order {Model.ProdId}";
    Layout = "_Layout";
    
    var configJson = System.Text.Json.JsonSerializer.Serialize(new {
        recId = Model.RecId,
        prodId = Model.ProdId,
        prodDate = Model.ProdDate.ToString("yyyy-MM-dd"),
        customerId = Model.CustomerId,
        customerName = Model.CustomerName,
        itemId = Model.ItemId,
        itemName = Model.ItemName,
        planQty = Model.PlanQty,
        notes = Model.Notes ?? ""
    });
}

<div x-data="prodEditForm(@configJson)" x-init="init()">
    @Html.AntiForgeryToken()
    
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Edit Production Order</h5>
                </div>
                <div class="card-body">
                    <form id="prod-form" method="post">
                        <input type="hidden" name="RecId" value="@Model.RecId" />
                        <input type="hidden" name="ProdId" value="@Model.ProdId" />
                        
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label class="form-label">Production ID</label>
                                <input type="text" class="form-control bg-light" value="@Model.ProdId" readonly />
                            </div>
                            <div class="col-md-3">
                                <label for="ProdDate" class="form-label">Production Date <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <input type="text" 
                                           id="ProdDate" 
                                           name="ProdDate"
                                           class="form-control"
                                           x-ref="prodDatePicker"
                                           data-flatpickr
                                           required />
                                    <span class="input-group-text"><i class="ri-calendar-line"></i></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label for="CustomerId" class="form-label">Customer <span class="text-danger">*</span></label>
                                <select class="form-control form-select"
                                        id="CustomerId" 
                                        name="CustomerId"
                                        x-ref="customerSelect"
                                        data-tomselect
                                        data-url="/api/Customers/cbo"
                                        required>
                                    <option value="">Select Customer</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label for="ItemId" class="form-label">Item <span class="text-danger">*</span></label>
                                <select class="form-control form-select"
                                        id="ItemId" 
                                        name="ItemId"
                                        x-ref="itemSelect"
                                        data-tomselect
                                        data-url="/api/Items/cbo"
                                        required>
                                    <option value="">Select Item</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label for="PlanQty" class="form-label">Planned Quantity <span class="text-danger">*</span></label>
                                <input type="text" 
                                       id="PlanQty" 
                                       name="PlanQty"
                                       class="form-control text-end"
                                       min="0.01"
                                       :value="form.planQty"
                                       x-mask:dynamic="$money($input, '.', ',')"
                                       required />
                            </div>
                            <div class="col-md-9">
                                <label for="Notes" class="form-label">Notes (Optional)</label>
                                <textarea id="Notes"
                                          name="Notes"
                                          class="form-control" 
                                          rows="1" 
                                          maxlength="100"
                                          x-model="form.notes"></textarea>
                            </div>
                        </div>
                        
                        <div class="form-group d-flex gap-2">
                            <button type="submit" class="btn btn-primary" :disabled="isSubmitting">
                                <span x-show="!isSubmitting">
                                    <i class="ri-save-line me-1"></i> Save Changes
                                </span>
                                <span x-show="isSubmitting" x-cloak>
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    Saving...
                                </span>
                            </button>
                            <a href="/Prods" class="btn btn-secondary">
                                <i class="ri-arrow-left-line me-1"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/prods/prod-edit.js"></script>
}

@model IEnumerable<ResearchApps.Service.Vm.CustomerOrderHeaderVm>

@{
    var customerId = ViewBag.CustomerId as int? ?? 0;
}

<table class="table table-bordered table-striped align-middle mb-0">
    <thead class="table-light">
        <tr>
            <th class="text-center" style="width: 120px;">CO No</th>
            <th style="width: 140px;">CO Date</th>
            <th class="text-end" style="width: 150px;">Total</th>
            <th class="text-center" style="width: 120px;">Status</th>
            <th class="text-center" style="width: 80px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td class="text-center">
                        <a href="@Url.Action("Details", "CustomerOrders", new { id = item.RecId })" class="text-primary fw-medium">
                            @item.CoId
                        </a>
                    </td>
                    <td>@item.CoDate.ToString("dd MMM yyyy")</td>
                    <td class="text-end">@item.Total.ToString("C")</td>
                    <td class="text-center">@Html.Raw(item.CoStatusName)</td>
                    <td class="text-center">
                        <div class="dropdown d-inline-block">
                            <button class="btn btn-soft-secondary btn-sm dropdown" type="button" 
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="ri-more-fill align-middle"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a href="@Url.Action("Details", "CustomerOrders", new { id = item.RecId })" class="dropdown-item">
                                        <i class="ri-eye-fill align-bottom me-2 text-muted"></i> View
                                    </a>
                                </li>
                                <li>
                                    <a href="@Url.Action("Edit", "CustomerOrders", new { id = item.RecId })" class="dropdown-item">
                                        <i class="ri-pencil-fill align-bottom me-2 text-muted"></i> Edit
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted py-4">
                    <i class="ri-inbox-line fs-3 d-block mb-2"></i>
                    No orders found for this customer.
                </td>
            </tr>
        }
    </tbody>
</table>

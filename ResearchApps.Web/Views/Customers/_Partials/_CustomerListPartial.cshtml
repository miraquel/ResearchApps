@model ResearchApps.Service.Vm.Common.PagedListVm<ResearchApps.Service.Vm.CustomerVm>

@if (Model.Items.Any())
{
    foreach (var item in Model.Items)
    {
        <tr>
            <td class="text-center">@item.CustomerId</td>
            <td><strong>@item.CustomerName</strong></td>
            <td>@(item.Address ?? "-")</td>
            <td class="text-center">@(item.City ?? "-")</td>
            <td class="text-center">@(item.Telp ?? "-")</td>
            <td>@(item.Email ?? "-")</td>
            <td class="text-center">@(item.TopName ?? "-")</td>
            <td class="text-center">
                @if (item.IsPpn)
                {
                    <span class="badge bg-info">Yes</span>
                }
                else
                {
                    <span class="badge bg-secondary">No</span>
                }
            </td>
            <td class="text-center">@Html.Raw(item.StatusName)</td>
            <td class="text-center">
                @* Actions dropdown *@
                <div class="dropdown d-inline-block">
                    <button class="btn btn-soft-secondary btn-sm dropdown" type="button" 
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="ri-more-fill align-middle"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a href="/Customers/Details/@item.CustomerId" class="dropdown-item">
                                <i class="ri-eye-fill align-bottom me-2 text-muted"></i> View
                            </a>
                        </li>
                        <li>
                            <a href="/Customers/Edit/@item.CustomerId" class="dropdown-item">
                                <i class="ri-pencil-fill align-bottom me-2 text-muted"></i> Edit
                            </a>
                        </li>
                        <li>
                            <a href="/CustomerOrders/Create?customerId=@item.CustomerId" class="dropdown-item">
                                <i class="ri-file-add-line align-bottom me-2 text-muted"></i> New CO
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a href="/Customers/Delete/@item.CustomerId" class="dropdown-item text-danger">
                                <i class="ri-delete-bin-fill align-bottom me-2"></i> Delete
                            </a>
                        </li>
                    </ul>
                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="10" class="text-center text-muted py-4">
            <i class="ri-inbox-line fs-2"></i>
            <p class="mb-0 mt-2">No customers found</p>
        </td>
    </tr>
}

@using ResearchApps.Common.Constants
@model ResearchApps.Service.Vm.CustomerVm

@{
    ViewBag.Title = "Customer Details";
    ViewBag.pTitle = "Customer Details";
    Layout = "_Layout";
}

@section styles {
}

@Html.AntiForgeryToken()

<div class="card">
    <div class="card-header">
        <div class="row">
            <div class="col d-flex justify-content-between align-items-center">
                <ul class="nav nav-tabs-custom rounded card-header-tabs border-bottom-0" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" data-bs-toggle="tab" href="#overview">Overview</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" data-bs-toggle="tab" href="#orders">Orders</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" data-bs-toggle="tab" href="#log">Log</a>
                    </li>
                </ul>
                <div class="position-absolute top-0 end-0">
                    @if(User.HasClaim("permission", PermissionConstants.CustomerOrders.Create))
                    {
                        <a href="@Url.Action("Create", "CustomerOrders", new { customerId = Model.CustomerId })" class="btn btn-sm btn-info me-2">
                            <i class="ri-file-add-line"></i> New CO
                        </a>
                    }
                    @if(User.HasClaim("permission", PermissionConstants.Customers.Edit))
                    {
                        <a href="@Url.Action("Edit", "Customers", new { id = Model.CustomerId })" class="btn btn-sm btn-success me-2">
                            <i class="ri-edit-line"></i> Edit
                        </a>
                    }
                    @if (User.HasClaim("permission", PermissionConstants.Customers.Delete))
                    {
                        <a href="@Url.Action("Delete", "Customers", new { id = Model.CustomerId })" class="btn btn-sm btn-danger">
                            <i class="ri-delete-bin-line"></i> Delete
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="tab-content">
            <div class="tab-pane active" id="overview" role="tabpanel">
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.CustomerId)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.CustomerId)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.CustomerName)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.CustomerName)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ContactPerson)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.ContactPerson)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.Telp)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.Telp)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.Email)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.Email)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.Address)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.Address)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.City)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.City)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.PostalCode)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.PostalCode)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.IsActive)</strong></div>
                    <div class="col-9">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }
                    </div>
                </div>
            </div>
            <div class="tab-pane" id="orders" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="mb-0">Customer Orders</h6>
                    <div class="d-flex gap-2 align-items-center">
                        <div id="ordersLoadingIndicator" class="htmx-indicator d-flex align-items-center text-muted">
                            <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <small>Loading...</small>
                        </div>
                        <button type="button" 
                                class="btn btn-sm btn-soft-secondary" 
                                hx-get="@Url.Action("CustomerOrders", "Customers", new { customerId = Model.CustomerId })"
                                hx-target="#customer-orders-container"
                                hx-swap="innerHTML"
                                hx-indicator="#ordersLoadingIndicator"
                                title="Refresh Orders">
                            <i class="ri-refresh-line"></i> Refresh
                        </button>
                    </div>
                </div>
                <div id="customer-orders-container"
                     hx-get="@Url.Action("CustomerOrders", "Customers", new { customerId = Model.CustomerId })"
                     hx-trigger="load"
                     hx-swap="innerHTML"
                     hx-indicator="#ordersLoadingIndicator">
                </div>
            </div>
            <div class="tab-pane" id="log" role="tabpanel">
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.CreatedDate)</strong></div>
                    <div class="col-9">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm:ss")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.CreatedBy)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.CreatedBy)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ModifiedDate)</strong></div>
                    <div class="col-9">@Model.ModifiedDate.ToString("dd MMM yyyy HH:mm:ss")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ModifiedBy)</strong></div>
                    <div class="col-9">@Model.ModifiedBy</div>
                </div>
            </div>
        </div>
    </div>
</div>

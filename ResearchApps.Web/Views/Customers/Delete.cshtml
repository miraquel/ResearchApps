@model ResearchApps.Service.Vm.CustomerVm

@{
    ViewBag.Title = "Delete Customer";
    ViewBag.pTitle = "Delete Customer";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-lg-12">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">
                    <i class="ri-alert-line"></i> Confirm Delete
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-warning" role="alert">
                    <i class="ri-error-warning-line me-2"></i>
                    Are you sure you want to delete this customer? This action cannot be undone.
                </div>
                
                <dl class="row">
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.CustomerId)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.CustomerId)</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.CustomerName)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.CustomerName)</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.ContactPerson)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.ContactPerson)</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Telp)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.Telp)</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Email)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.Email)</dd>
                </dl>
                
                <form asp-action="Delete" asp-route-id="@Model.CustomerId" method="post" id="delete-customer-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CustomerId" />
                </form>
                <div class="form-group mt-4">
                    <button type="button" class="btn btn-danger"
                            data-confirm
                            data-confirm-modal="deleteModal"
                            data-confirm-form="#delete-customer-form"
                            data-confirm-title="Confirm Delete"
                            data-confirm-message="Are you sure you want to delete this customer? This action cannot be undone.">
                        <i class="ri-delete-bin-line"></i> Delete
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.CustomerId" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>

@model ResearchApps.Service.Vm.MaterialCustomerHeaderVm

@{
    ViewBag.Title = "Delete Material Customer";
    ViewBag.pTitle = $"Delete Material Customer {Model.McId}";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card">
            <div class="card-header bg-danger-subtle">
                <h5 class="card-title mb-0 text-danger">
                    <i class="ri-delete-bin-line me-2"></i>Delete Material Customer
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-danger">
                    <i class="ri-error-warning-line me-2"></i>
                    <strong>Warning:</strong> This action cannot be undone. Are you sure you want to delete this material customer record?
                </div>
                
                <table class="table table-borderless">
                    <tr>
                        <td class="fw-bold" style="width: 150px;">MC No</td>
                        <td>@Model.McId</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">MC Date</td>
                        <td>@Model.McDate.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Customer</td>
                        <td>@Model.CustomerName</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">SJ No</td>
                        <td>@(string.IsNullOrEmpty(Model.SjNo) ? "-" : Model.SjNo)</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Reference No</td>
                        <td>@(string.IsNullOrEmpty(Model.RefNo) ? "-" : Model.RefNo)</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Notes</td>
                        <td>@(string.IsNullOrEmpty(Model.Notes) ? "-" : Model.Notes)</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Created By</td>
                        <td>@Model.CreatedBy</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Created Date</td>
                        <td>@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                </table>
                
                <form method="post" action="/MaterialCustomers/DeleteConfirmed" id="delete-materialcustomer-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="recId" value="@Model.RecId" />
                </form>
                <div class="d-flex gap-2 mt-4">
                    <button type="button" class="btn btn-danger"
                            data-confirm
                            data-confirm-modal="deleteModal"
                            data-confirm-form="#delete-materialcustomer-form"
                            data-confirm-title="Confirm Delete"
                            data-confirm-message="Are you sure you want to delete this material customer record? This action cannot be undone.">
                        <i class="ri-delete-bin-line me-1"></i> Delete
                    </button>
                    <a href="/MaterialCustomers/Details/@Model.RecId" class="btn btn-secondary">
                        <i class="ri-arrow-left-line me-1"></i> Cancel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

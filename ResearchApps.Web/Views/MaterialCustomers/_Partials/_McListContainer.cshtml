@model ResearchApps.Service.Vm.Common.PagedListVm<ResearchApps.Service.Vm.MaterialCustomerHeaderVm>

<table class="table table-bordered table-hover align-middle mb-0" style="width: 100%;">
    <thead class="table-light">
    <tr>
        <th class="sortable-header" style="width: 140px; cursor: pointer;" 
            @@click="sort('McId')" data-column="McId">
            <div class="d-flex align-items-center justify-content-center">
                <span>MC ID</span>
                <template x-if="sortBy === 'McId'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="width: 130px; cursor: pointer;"
            @@click="sort('McDate')" data-column="McDate">
            <div class="d-flex align-items-center justify-content-center">
                <span>Date</span>
                <template x-if="sortBy === 'McDate'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="min-width: 250px; cursor: pointer;"
            @@click="sort('CustomerName')" data-column="CustomerName">
            <div class="d-flex align-items-center">
                <span>Customer</span>
                <template x-if="sortBy === 'CustomerName'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="width: 140px; cursor: pointer;"
            @@click="sort('SjNo')" data-column="SjNo">
            <div class="d-flex align-items-center justify-content-center">
                <span>SJ No</span>
                <template x-if="sortBy === 'SjNo'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="width: 140px; cursor: pointer;"
            @@click="sort('RefNo')" data-column="RefNo">
            <div class="d-flex align-items-center justify-content-center">
                <span>Ref No</span>
                <template x-if="sortBy === 'RefNo'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="width: 120px; cursor: pointer;"
            @@click="sort('McStatusId')" data-column="McStatusId">
            <div class="d-flex align-items-center justify-content-center">
                <span>Status</span>
                <template x-if="sortBy === 'McStatusId'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="text-center" style="width: 80px;">Actions</th>
    </tr>
    </thead>
    <tbody id="mc-table-body">
    @await Html.PartialAsync("_Partials/_McListPartial", Model)
    </tbody>
    <tfoot class="table-light">
    <tr>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search ID..."
                   x-model="filters.McId" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <div id="mc-date-range" class="flatpickr input-group">
                <input type="text" class="form-control form-control-sm" placeholder="Select date range..." data-input>
                <button class="btn btn-sm btn-outline-secondary" type="button" title="Clear" data-clear>
                    <i class="ri-close-line"></i>
                </button>
            </div>
        </td>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search customer name..."
                   x-model="filters.CustomerName" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search SJ No..."
                   x-model="filters.SjNo" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search ref no..."
                   x-model="filters.RefNo" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <select class="form-select form-select-sm" x-model="filters.McStatusId" @@change="fetchList()">
                <option value="">All Statuses</option>
                <option value="0">Draft</option>
                <option value="1">Active</option>
                <option value="2">Completed</option>
                <option value="3">Cancelled</option>
            </select>
        </td>
        <td class="text-center">
            <button type="button" class="btn btn-sm btn-outline-secondary w-100" @@click="clearFilters()" title="Clear All Filters">
                <i class="ri-filter-off-line"></i>
            </button>
        </td>
    </tr>
    </tfoot>
</table>

<div class="mt-3">
    @await Html.PartialAsync("_Partials/_McPaginationPartial", Model)
</div>

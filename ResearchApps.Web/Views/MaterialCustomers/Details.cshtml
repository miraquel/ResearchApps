@model ResearchApps.Service.Vm.MaterialCustomerVm

@{
    ViewBag.Title = "Material Customer Details";
    ViewBag.pTitle = $"Material Customer {Model.Header.McId}";
    Layout = "_Layout";
}

<div x-data="mcDetails('@Model.Header.McId', @Model.Header.RecId)" x-init="init()">
    @Html.AntiForgeryToken()
    
    <div id="mcDetails" class="card">
        <div class="card-header">
            <div class="row">
                <div class="col d-flex justify-content-between align-items-center">
                    <ul class="nav nav-tabs-custom rounded card-header-tabs border-bottom-0" role="tablist">
                        <li class="nav-item" role="presentation">
                            <a class="nav-link active" data-bs-toggle="tab" href="#overview">Overview</a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a class="nav-link" data-bs-toggle="tab" href="#lines">Lines</a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a class="nav-link" data-bs-toggle="tab" href="#log">Log</a>
                        </li>
                    </ul>
                    <div class="position-absolute top-0 end-0">
                        <!-- Loading Indicator -->
                        <span x-show="isLoading" x-cloak class="spinner-border spinner-border-sm text-primary"></span>
                        
                        @if (User.Identity?.Name == Model.Header.CreatedBy)
                        {
                            <a href="/MaterialCustomers/Edit/@Model.Header.RecId" class="btn btn-sm btn-success">
                                <i class="ri-edit-line"></i> Edit
                            </a>
                        }
                        
                        @if (User.Identity?.Name == Model.Header.CreatedBy)
                        {
                            <a href="/MaterialCustomers/Delete/@Model.Header.RecId" class="btn btn-sm btn-danger">
                                <i class="ri-delete-bin-line"></i> Delete
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="tab-content">
                <!-- Overview Tab -->
                <div class="tab-pane active" id="overview" role="tabpanel">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <td class="fw-bold" style="width: 150px;">MC No</td>
                                    <td>@Model.Header.McId</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">MC Date</td>
                                    <td>@Model.Header.McDate.ToString("dd MMM yyyy")</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">Customer</td>
                                    <td><a href="/Customers/Details/@Model.Header.CustomerId">@Model.Header.CustomerName</a></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">SJ No</td>
                                    <td>@(string.IsNullOrEmpty(Model.Header.SjNo) ? "-" : Model.Header.SjNo)</td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <td class="fw-bold" style="width: 150px;">Status</td>
                                    <td>@Html.Raw(Model.Header.McStatusName)</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">Reference No</td>
                                    <td>@(string.IsNullOrEmpty(Model.Header.RefNo) ? "-" : Model.Header.RefNo)</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">Notes</td>
                                    <td>@(string.IsNullOrEmpty(Model.Header.Notes) ? "-" : Model.Header.Notes)</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
                
                <!-- Lines Tab -->
                <div class="tab-pane" id="lines" role="tabpanel">
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 50px;">#</th>
                                    <th>Item</th>
                                    <th>Warehouse</th>
                                    <th class="text-end" style="width: 120px;">Qty</th>
                                    <th class="text-center" style="width: 100px;">Unit</th>
                                    <th style="min-width: 150px;">Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int lineNumber = 0; }
                                @foreach (var line in Model.Lines)
                                {
                                    lineNumber++;
                                    <tr>
                                        <td class="text-center">@lineNumber</td>
                                        <td>@line.ItemName</td>
                                        <td>@line.WhName</td>
                                        <td class="text-end">@line.Qty.ToString("N2")</td>
                                        <td class="text-center">@line.UnitName</td>
                                        <td>@(string.IsNullOrEmpty(line.Notes) ? "-" : line.Notes)</td>
                                    </tr>
                                }
                                @if (!Model.Lines.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="ri-inbox-line fs-2"></i>
                                            <p class="mb-0 mt-2">No lines found</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <!-- Log Tab -->
                <div class="tab-pane" id="log" role="tabpanel">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <td class="fw-bold" style="width: 150px;">Created By</td>
                                    <td>@Model.Header.CreatedBy</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">Created Date</td>
                                    <td>@Model.Header.CreatedDate.ToString("dd MMM yyyy HH:mm")</td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <td class="fw-bold" style="width: 150px;">Modified By</td>
                                    <td>@Model.Header.ModifiedBy</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">Modified Date</td>
                                    <td>@Model.Header.ModifiedDate.ToString("dd MMM yyyy HH:mm")</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-3">
        <a href="/MaterialCustomers" class="btn btn-secondary">
            <i class="ri-arrow-left-line me-1"></i> Back to List
        </a>
    </div>
</div>

@section scripts {
    <script src="~/js/material-customers/mc-details.js"></script>
}

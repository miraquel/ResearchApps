@model ResearchApps.Service.Vm.MaterialCustomerVm

@{
    ViewBag.Title = "Edit Material Customer";
    ViewBag.pTitle = $"Edit Material Customer No. {Model.Header.McId}";
    Layout = "_Layout";
    
    // Serialize lines for Alpine.js with camelCase
    var linesJson = System.Text.Json.JsonSerializer.Serialize(Model.Lines.Select(l => new {
        mcLineId = l.McLineId,
        itemId = l.ItemId,
        itemName = l.ItemName,
        whId = l.WhId,
        whName = l.WhName,
        qty = l.Qty,
        unitName = l.UnitName,
        price = l.Price,
        notes = l.Notes ?? "",
        mcStatusId = l.McStatusId
    }));
    
    // Config object for mcEdit component
    var configJson = System.Text.Json.JsonSerializer.Serialize(new {
        recId = Model.Header.RecId,
        mcId = Model.Header.McId,
        mcDate = Model.Header.McDate.ToString("yyyy-MM-dd"),
        customerId = Model.Header.CustomerId,
        customerName = Model.Header.CustomerName,
        sjNo = Model.Header.SjNo ?? "",
        refNo = Model.Header.RefNo ?? "",
        notes = Model.Header.Notes ?? ""
    });
}

<div x-data="mcEdit(@linesJson, @configJson)" x-init="init()">
    @Html.AntiForgeryToken()
    
    <!-- Header Section -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">
                                MC Header @Html.Raw(Model.Header.McStatusName)
                                <span x-show="isHeaderSaving" x-cloak class="spinner-border spinner-border-sm text-primary ms-2"></span>
                            </h5>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <form id="mcForm" method="post">
                        <input type="hidden" name="RecId" value="@Model.Header.RecId" />
                        <input type="hidden" name="McId" value="@Model.Header.McId" />
                        <input type="hidden" name="McStatusId" value="@Model.Header.McStatusId" />
                        <input type="hidden" name="CreatedDate" value="@Model.Header.CreatedDate.ToString("o")" />
                        <input type="hidden" name="CreatedBy" value="@Model.Header.CreatedBy" />
                        
                        <div class="row">
                            <!-- Left Column -->
                            <div class="col-md-4">
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label class="form-label">MC No</label>
                                            <input type="text" class="form-control bg-light" value="@Model.Header.McId" readonly />
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label class="form-label">Customer</label>
                                            <input type="text" class="form-control bg-light" value="@Model.Header.CustomerName" readonly />
                                            <input type="hidden" name="CustomerId" value="@Model.Header.CustomerId" />
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label class="form-label">SJ No</label>
                                            <input type="text" class="form-control bg-light" value="@Model.Header.SjNo" readonly />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Middle Column -->
                            <div class="col-md-4">
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label class="form-label">MC Date</label>
                                            <input type="text" class="form-control bg-light" value="@Model.Header.McDate.ToString("dd MMM yyyy")" readonly />
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label class="form-label">Reference No</label>
                                            <input type="text" class="form-control bg-light" value="@Model.Header.RefNo" readonly />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Right Column -->
                            <div class="col-md-4">
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label class="form-label">Notes (Optional)</label>
                                            <textarea name="Notes" 
                                                      class="form-control" 
                                                      rows="4"
                                                      x-model="header.notes">@Model.Header.Notes</textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-group d-flex gap-2">
                            <button type="button" 
                                    class="btn btn-primary"
                                    @@click="saveHeader()"
                                    :disabled="isHeaderSaving">
                                <span x-show="!isHeaderSaving"><i class="ri-save-line me-1"></i> Save Changes</span>
                                <span x-show="isHeaderSaving" x-cloak>
                                    <span class="spinner-border spinner-border-sm me-1"></span> Saving...
                                </span>
                            </button>
                            
                            <a href="/MaterialCustomers/Details/@Model.Header.RecId" class="btn btn-secondary">
                                <i class="ri-arrow-left-line me-1"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- MC Lines Section -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        MC Lines 
                        <span class="badge bg-primary-subtle text-primary" x-text="lines.length"></span>
                    </h5>
                    <button type="button" class="btn btn-primary btn-sm" @@click="showLineModal('add')">
                        <i class="ri-add-line"></i> Add Line
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 50px;">#</th>
                                    <th>Item</th>
                                    <th>Warehouse</th>
                                    <th class="text-end" style="width: 120px;">Qty</th>
                                    <th class="text-center" style="width: 100px;">Unit</th>
                                    <th style="min-width: 150px;">Notes</th>
                                    <th class="text-center" style="width: 100px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <template x-if="lines.length === 0">
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">
                                            <i class="ri-inbox-line fs-2"></i>
                                            <p class="mb-0 mt-2">No lines added yet. Click "Add Line" to add items.</p>
                                        </td>
                                    </tr>
                                </template>
                                <template x-for="(line, index) in lines" :key="line.mcLineId || index">
                                    <tr>
                                        <td class="text-center" x-text="index + 1"></td>
                                        <td x-text="line.itemName"></td>
                                        <td x-text="line.whName"></td>
                                        <td class="text-end" x-text="formatNumber(line.qty)"></td>
                                        <td class="text-center" x-text="line.unitName"></td>
                                        <td x-text="line.notes || '-'"></td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-soft-danger" 
                                                    @@click="deleteLine(line)" title="Delete">
                                                <i class="ri-delete-bin-line"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </template>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Add Line Modal -->
    <div class="modal fade" 
         :class="{ 'show d-block': lineModal.show }"
         x-show="lineModal.show"
         x-cloak
         tabindex="-1"
         @@keydown.escape.window="lineModal.show = false">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="ri-add-line me-2"></i>Add Line
                    </h5>
                    <button type="button" class="btn-close" @@click="closeLineModal()"></button>
                </div>
                <div class="modal-body">
                    <form id="lineForm">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Item <span class="text-danger">*</span></label>
                                <select id="lineItemId"
                                        x-ref="lineItemSelect"
                                        data-tomselect
                                        data-url="/api/Items/cbo"
                                        required>
                                    <option value="">Select Item</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Warehouse <span class="text-danger">*</span></label>
                                <select id="lineWhId"
                                        x-ref="lineWhSelect"
                                        data-tomselect
                                        data-url="/api/Warehouses/cbo"
                                        required>
                                    <option value="">Select Warehouse</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Quantity <span class="text-danger">*</span></label>
                                <input type="text" 
                                       class="form-control" 
                                       x-model.number="lineModal.data.qty"
                                       min="0.01"
                                       x-mask:dynamic="$money($input, '.', ',')"
                                       required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Notes</label>
                                <input type="text" 
                                       class="form-control" 
                                       x-model="lineModal.data.notes"
                                       maxlength="100" />
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="closeLineModal()">Cancel</button>
                    <button type="button" 
                            class="btn btn-primary" 
                            @@click="saveLine()"
                            :disabled="lineModal.isSaving">
                        <span x-show="!lineModal.isSaving">
                            <i class="ri-save-line me-1"></i> Add Line
                        </span>
                        <span x-show="lineModal.isSaving" x-cloak>
                            <span class="spinner-border spinner-border-sm me-1"></span> Saving...
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show" x-show="lineModal.show" x-cloak></div>
    
    <!-- Delete Line Confirmation Modal -->
    <div class="modal fade" 
         :class="{ 'show d-block': deleteModal.show }"
         x-show="deleteModal.show"
         x-cloak
         tabindex="-1"
         @@keydown.escape.window="deleteModal.show = false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">
                        <i class="ri-delete-bin-line me-2"></i>Delete Line
                    </h5>
                    <button type="button" class="btn-close" @@click="deleteModal.show = false"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this line?</p>
                    <div class="alert alert-warning">
                        <strong>Item:</strong> <span x-text="deleteModal.line?.itemName"></span><br>
                        <strong>Qty:</strong> <span x-text="formatNumber(deleteModal.line?.qty)"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="deleteModal.show = false">Cancel</button>
                    <button type="button" 
                            class="btn btn-danger" 
                            @@click="confirmDeleteLine()"
                            :disabled="deleteModal.isDeleting">
                        <span x-show="!deleteModal.isDeleting">
                            <i class="ri-delete-bin-line me-1"></i> Delete
                        </span>
                        <span x-show="deleteModal.isDeleting" x-cloak>
                            <span class="spinner-border spinner-border-sm me-1"></span> Deleting...
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show" x-show="deleteModal.show" x-cloak></div>
</div>

@section scripts {
    <script src="~/js/material-customers/mc-edit.js"></script>
}

@model ResearchApps.Service.Vm.BudgetVm

@{
    ViewBag.Title = "Budget Details";
    ViewBag.pTitle = $"Budget - {Model.BudgetName}";
    Layout = "_Layout";
}

<div id="budgetDetails" class="card">
    <div class="card-header">
        <div class="row">
            <div class="col d-flex justify-content-between align-items-center">
                <ul class="nav nav-tabs-custom rounded card-header-tabs border-bottom-0" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" data-bs-toggle="tab" href="#overview">Overview</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" data-bs-toggle="tab" href="#log">Log</a>
                    </li>
                </ul>
                <div class="position-absolute top-0 end-0">
                    <a href="/Budgets/Edit/@Model.BudgetId" class="btn btn-sm btn-soft-warning">
                        <i class="ri-edit-line"></i> Edit
                    </a>
                    <a href="/Budgets/Delete/@Model.BudgetId" class="btn btn-sm btn-soft-danger">
                        <i class="ri-delete-bin-line"></i> Delete
                    </a>
                    <a href="/Budgets/Index" class="btn btn-sm btn-soft-secondary">
                        <i class="ri-arrow-left-line"></i> Back
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="tab-content">
            <!-- Overview Tab -->
            <div class="tab-pane active" id="overview" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <td class="fw-bold" style="width: 150px;">Budget ID</td>
                                <td>@Model.BudgetId</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Budget Name</td>
                                <td>@Model.BudgetName</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Year</td>
                                <td>@Model.Year</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Start Date</td>
                                <td>@Model.StartDate.ToString("dd MMM yyyy")</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">End Date</td>
                                <td>@Model.EndDate.ToString("dd MMM yyyy")</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <td class="fw-bold" style="width: 170px;">Amount</td>
                                <td>@Model.Amount.ToString("N0")</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Remaining Amount</td>
                                <td>@Model.RemAmount.ToString("N0")</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Used Amount</td>
                                <td>@((Model.Amount - Model.RemAmount).ToString("N0"))</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Status</td>
                                <td>@Html.Raw(Model.StatusName)</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Log Tab -->
            <div class="tab-pane" id="log" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <td class="fw-bold" style="width: 150px;">Created Date</td>
                                <td>@(Model.CreatedDate?.ToString("dd MMM yyyy HH:mm:ss") ?? "-")</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Created By</td>
                                <td>@(string.IsNullOrEmpty(Model.CreatedBy) ? "-" : Model.CreatedBy)</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <td class="fw-bold" style="width: 150px;">Modified Date</td>
                                <td>@(Model.ModifiedDate?.ToString("dd MMM yyyy HH:mm:ss") ?? "-")</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Modified By</td>
                                <td>@(string.IsNullOrEmpty(Model.ModifiedBy) ? "-" : Model.ModifiedBy)</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@model ResearchApps.Service.Vm.BudgetVm

@{
    ViewBag.Title = "Delete Budget";
    ViewBag.pTitle = "Delete Budget";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-lg-12">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">
                    <i class="ri-alert-line"></i> Confirm Delete
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-warning" role="alert">
                    <i class="ri-error-warning-line me-2"></i>
                    Are you sure you want to delete this budget? This action cannot be undone.
                </div>

                <dl class="row">
                    <dt class="col-sm-3">Budget ID</dt>
                    <dd class="col-sm-9">@Model.BudgetId</dd>

                    <dt class="col-sm-3">Budget Name</dt>
                    <dd class="col-sm-9">@Model.BudgetName</dd>

                    <dt class="col-sm-3">Year</dt>
                    <dd class="col-sm-9">@Model.Year</dd>

                    <dt class="col-sm-3">Start Date</dt>
                    <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-3">End Date</dt>
                    <dd class="col-sm-9">@Model.EndDate.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-3">Amount</dt>
                    <dd class="col-sm-9">@Model.Amount.ToString("N0")</dd>

                    <dt class="col-sm-3">Remaining Amount</dt>
                    <dd class="col-sm-9">@Model.RemAmount.ToString("N0")</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">@Html.Raw(Model.StatusName)</dd>
                </dl>

                <form asp-action="Delete" method="post" id="delete-budget-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="BudgetId" />
                </form>
                <div class="form-group mt-4">
                    <button type="button" class="btn btn-danger"
                            data-confirm
                            data-confirm-modal="deleteModal"
                            data-confirm-form="#delete-budget-form"
                            data-confirm-title="Confirm Delete"
                            data-confirm-message="Are you sure you want to delete this budget? This action cannot be undone.">
                        <i class="ri-delete-bin-line"></i> Delete
                    </button>
                    <a href="/Budgets/Details/@Model.BudgetId" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>

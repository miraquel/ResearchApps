@model ResearchApps.Service.Vm.Common.PagedListVm<ResearchApps.Service.Vm.BudgetVm>

@if (Model.Items.Any())
{
    foreach (var item in Model.Items)
    {
        <tr>
            <td class="text-center">@item.BudgetId</td>
            <td class="text-center">@item.Year</td>
            <td><strong>@item.BudgetName</strong></td>
            <td class="text-center">@item.StartDateStr</td>
            <td class="text-center">@item.EndDateStr</td>
            <td class="text-end">@item.Amount.ToString("N0")</td>
            <td class="text-end">@item.RemAmount.ToString("N0")</td>
            <td class="text-center">@Html.Raw(item.StatusName)</td>
            <td class="text-center">
                @* Actions dropdown *@
                <div class="dropdown d-inline-block">
                    <button class="btn btn-soft-secondary btn-sm dropdown" type="button"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="ri-more-fill align-middle"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a href="/Budgets/Details/@item.BudgetId" class="dropdown-item">
                                <i class="ri-eye-fill align-bottom me-2 text-muted"></i> View
                            </a>
                        </li>
                        <li>
                            <a href="/Budgets/Edit/@item.BudgetId" class="dropdown-item">
                                <i class="ri-pencil-fill align-bottom me-2 text-muted"></i> Edit
                            </a>
                        </li>
                        <li>
                            <a href="/Budgets/Delete/@item.BudgetId" class="dropdown-item">
                                <i class="ri-delete-bin-fill align-bottom me-2 text-muted"></i> Delete
                            </a>
                        </li>
                    </ul>
                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="9" class="text-center text-muted py-4">
            <i class="ri-inbox-line fs-2"></i>
            <p class="mb-0 mt-2">No budgets found</p>
        </td>
    </tr>
}

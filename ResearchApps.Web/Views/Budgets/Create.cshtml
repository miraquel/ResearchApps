@model ResearchApps.Service.Vm.BudgetVm

@{
    ViewData["Title"] = "Create Budget";
    ViewBag.Title = "Create Budget";
    ViewBag.pTitle = "Create Budget";
    Layout = "_Layout";
}

@* Alpine.js component for budget creation form *@
<div x-data="budgetCreate()">
    @* Page header with title and back button *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Create Budget</h2>
        <a asp-action="Index" class="btn btn-soft-secondary">
            <i class="ri-arrow-left-line align-bottom me-1"></i> Back to List
        </a>
    </div>

    @* Form card *@
    <div class="card">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6">
                        <h5 class="mb-3">Budget Information</h5>

                        <div class="mb-3">
                            <label asp-for="BudgetName" class="form-label"></label>
                            <input asp-for="BudgetName" class="form-control" placeholder="Enter budget name" required />
                            <span asp-validation-for="BudgetName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StartDate" class="form-label"></label>
                            <input asp-for="StartDate" type="text" class="form-control" x-ref="startDate"
                                   data-flatpickr placeholder="Select start date" required readonly />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EndDate" class="form-label"></label>
                            <input asp-for="EndDate" type="text" class="form-control" x-ref="endDate"
                                   data-flatpickr placeholder="Select end date" required readonly />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h5 class="mb-3">Financial Details</h5>

                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label"></label>
                            <input type="text" class="form-control" inputmode="numeric"
                                   x-model="amountDisplay"
                                   @@input="formatAmount()"
                                   placeholder="Enter amount" required />
                            <input type="hidden" asp-for="Amount" x-model="amountValue" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>

                        <input type="hidden" asp-for="StatusId" value="1" />
                    </div>
                </div>

                <hr class="my-4">

                @* Form action buttons *@
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-soft-secondary">
                        <i class="ri-close-line align-bottom me-1"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="ri-save-line align-bottom me-1"></i> Create Budget
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/budgets/budget-create.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

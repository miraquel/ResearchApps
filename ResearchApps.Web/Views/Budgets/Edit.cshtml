@model ResearchApps.Service.Vm.BudgetVm

@{
    ViewBag.Title = "Edit Budget";
    ViewBag.pTitle = $"Edit Budget - {Model.BudgetName}";
    Layout = "_Layout";
}

<div x-data="budgetEdit(@Model.Amount, '@Model.StartDate.ToString("yyyy-MM-dd")', '@Model.EndDate.ToString("yyyy-MM-dd")')">
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">Edit Budget</h5>
                            <a href="/Budgets/Index" class="btn btn-sm btn-soft-secondary">
                                <i class="ri-arrow-left-line"></i> Back
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="BudgetId" />
                        <input type="hidden" asp-for="StatusId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">
                            <div class="col-md-6">
                                <h5 class="mb-3">Budget Information</h5>

                                <div class="mb-3">
                                    <label asp-for="BudgetName" class="form-label"></label>
                                    <input asp-for="BudgetName" class="form-control" placeholder="Enter budget name" required />
                                    <span asp-validation-for="BudgetName" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="StartDate" class="form-label"></label>
                                    <input asp-for="StartDate" type="text" class="form-control" x-ref="startDate"
                                           data-flatpickr placeholder="Select start date" required readonly />
                                    <span asp-validation-for="StartDate" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="EndDate" class="form-label"></label>
                                    <input asp-for="EndDate" type="text" class="form-control" x-ref="endDate"
                                           data-flatpickr placeholder="Select end date" required readonly />
                                    <span asp-validation-for="EndDate" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h5 class="mb-3">Financial Details</h5>

                                <div class="mb-3">
                                    <label asp-for="Amount" class="form-label"></label>
                                    <input type="text" class="form-control" inputmode="numeric"
                                           x-model="amountDisplay"
                                           @@input="formatAmount()"
                                           placeholder="Enter amount" required />
                                    <input type="hidden" asp-for="Amount" x-model="amountValue" />
                                    <span asp-validation-for="Amount" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="RemAmount" class="form-label"></label>
                                    <input type="text" class="form-control bg-light" readonly
                                           value="@Model.RemAmount.ToString("N0")" />
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="ri-save-line"></i> Save Changes
                            </button>
                            <a href="/Budgets/Index" class="btn btn-soft-secondary">
                                <i class="ri-arrow-left-line"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/budgets/budget-edit.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

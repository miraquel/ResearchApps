@model ResearchApps.Service.Vm.PsVm

@{
    ViewBag.Title = "Create Penyesuaian Stock";
    ViewBag.pTitle = "Create Penyesuaian Stock";
    Layout = "_Layout";
}

<div x-data="psCreateForm()" x-init="init()">
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Create New Penyesuaian Stock</h5>
                </div>
                <div class="card-body">
                    <form id="ps-form" 
                          method="post"
                          action="/Pss/Create">
                        @Html.AntiForgeryToken()
                        
                        <!-- Validation Summary -->
                        <div id="validation-summary" x-show="Object.keys(errors).length > 0" x-cloak>
                            <div class="alert alert-danger">
                                <template x-for="(error, field) in errors" :key="field">
                                    <div x-text="error"></div>
                                </template>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Header_PsDate" class="form-label">PS Date <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <input type="text" 
                                               id="Header_PsDate" 
                                               name="Header.PsDate"
                                               class="form-control"
                                               x-ref="psDatePicker"
                                               data-flatpickr
                                               :class="{ 'is-invalid': errors.PsDate }"
                                               required />
                                        <span class="input-group-text"><i class="ri-calendar-line"></i></span>
                                    </div>
                                    <div class="invalid-feedback" x-show="errors.PsDate" x-text="errors.PsDate"></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Header_Descr" class="form-label">Description <span class="text-danger">*</span></label>
                                    <input type="text" 
                                           id="Header_Descr" 
                                           name="Header.Descr"
                                           class="form-control"
                                           placeholder="Enter description"
                                           maxlength="50"
                                           :class="{ 'is-invalid': errors.Descr }"
                                           required />
                                    <div class="invalid-feedback" x-show="errors.Descr" x-text="errors.Descr"></div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label for="Header_Notes" class="form-label">Notes (Optional)</label>
                                    <textarea id="Header_Notes" 
                                              name="Header.Notes"
                                              class="form-control"
                                              rows="2"
                                              maxlength="100"
                                              placeholder="Enter notes"></textarea>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" 
                                    class="btn btn-primary"
                                    :disabled="isSubmitting">
                                <span x-show="!isSubmitting">
                                    <i class="ri-save-line me-1"></i> Save
                                </span>
                                <span x-show="isSubmitting" x-cloak>
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    Creating...
                                </span>
                            </button>
                            <a href="/Pss" class="btn btn-secondary">
                                <i class="ri-close-line me-1"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/pss/ps-create.js"></script>
}

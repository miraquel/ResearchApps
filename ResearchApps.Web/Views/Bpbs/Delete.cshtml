@model ResearchApps.Service.Vm.BpbVm

@{
    ViewBag.Title = "Delete BPB";
    ViewBag.pTitle = $"Delete BPB {Model.Header.BpbId}";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">
                    <i class="ri-delete-bin-line me-2"></i>
                    Confirm Delete
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="ri-error-warning-line me-2"></i>
                    <strong>Warning!</strong> This action cannot be undone. All line items will also be deleted.
                </div>
                
                <p>Are you sure you want to delete the following BPB?</p>
                
                <div class="card bg-light">
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label text-muted small">BPB No</label>
                                <p class="fw-bold">@Model.Header.BpbId</p>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted small">BPB Date</label>
                                <p>@Model.Header.BpbDateStr</p>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted small">Production ID</label>
                                <p>
                                    @(string.IsNullOrEmpty(Model.Header.RefId) ? "-" : Model.Header.RefId)
                                </p>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted small">Description</label>
                                <p>@(string.IsNullOrEmpty(Model.Header.Descr) ? "-" : Model.Header.Descr)</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small">Amount</label>
                                <p class="fw-bold text-danger">@Model.Header.Amount.ToString("N0")</p>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <label class="form-label text-muted small">Line Items</label>
                                <p>
                                    <span class="badge bg-secondary">@Model.Lines.Count() items</span>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <form asp-action="Delete" method="post" id="delete-bpb-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="recId" value="@Model.Header.RecId" />
                </form>
                <div class="d-flex justify-content-between">
                    <a href="/Bpbs" class="btn btn-secondary">
                        <i class="ri-arrow-left-line me-1"></i> Cancel
                    </a>
                    <button type="button" class="btn btn-danger"
                            data-confirm
                            data-confirm-modal="deleteModal"
                            data-confirm-form="#delete-bpb-form"
                            data-confirm-title="Confirm Delete"
                            data-confirm-message="Are you sure you want to delete this BPB? This action cannot be undone.">
                        <i class="ri-delete-bin-line me-1"></i> Delete BPB
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

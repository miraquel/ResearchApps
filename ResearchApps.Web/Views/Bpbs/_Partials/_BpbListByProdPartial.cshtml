@model List<ResearchApps.Service.Vm.BpbHeaderVm>

<div class="table-responsive">
    <table class="table table-sm table-hover table-striped align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th scope="col">BPB No</th>
                <th scope="col">Date</th>
                <th scope="col">Description</th>
                <th scope="col" class="text-end">Amount</th>
                <th scope="col">Status</th>
                <th scope="col">Created By</th>
                <th scope="col" style="width: 80px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <a href="/Bpbs/Details/@item.RecId" class="fw-medium text-primary">
                                @item.BpbId
                            </a>
                        </td>
                        <td>@item.BpbDateStr</td>
                        <td>@item.Descr</td>
                        <td class="text-end">@item.Amount.ToString("N0")</td>
                        <td>@Html.Raw(item.BpbStatusName)</td>
                        <td>@item.CreatedBy</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="/Bpbs/Details/@item.RecId" class="btn btn-sm btn-outline-info" title="View">
                                    <i class="ri-eye-line"></i>
                                </a>
                                <a href="/Bpbs/Edit/@item.RecId" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="ri-pencil-line"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        <i class="ri-inbox-line fs-3 d-block mb-2"></i>
                        No BPB records found for this production order.
                    </td>
                </tr>
            }
        </tbody>
        @if (Model.Any())
        {
            <tfoot class="table-light">
                <tr>
                    <th colspan="3" class="text-end">Total:</th>
                    <th class="text-end">@Model.Sum(m => m.Amount).ToString("N0")</th>
                    <th colspan="3"></th>
                </tr>
            </tfoot>
        }
    </table>
</div>

@model ResearchApps.Service.Vm.Common.PagedListVm<ResearchApps.Service.Vm.BpbHeaderVm>

@{
    var startItem = (Model.PageNumber - 1) * Model.PageSize + 1;
    var endItem = Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount);
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <div class="text-muted small">
        Showing @startItem to @endItem of @Model.TotalCount entries
    </div>
    <nav>
        <ul class="pagination pagination-sm mb-0">
            <!-- Previous -->
            <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                <a class="page-link" href="#" @@click.prevent="fetchList(@(Model.PageNumber - 1))">
                    <i class="ri-arrow-left-s-line"></i>
                </a>
            </li>
            
            @{
                var startPage = Math.Max(1, Model.PageNumber - 2);
                var endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);
                
                if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="#" @@click.prevent="fetchList(1)">1</a>
                    </li>
                    if (startPage > 2)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }
                }
                
                for (var i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" href="#" @@click.prevent="fetchList(@i)">@i</a>
                    </li>
                }
                
                if (endPage < Model.TotalPages)
                {
                    if (endPage < Model.TotalPages - 1)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }
                    <li class="page-item">
                        <a class="page-link" href="#" @@click.prevent="fetchList(@Model.TotalPages)">@Model.TotalPages</a>
                    </li>
                }
            }
            
            <!-- Next -->
            <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="#" @@click.prevent="fetchList(@(Model.PageNumber + 1))">
                    <i class="ri-arrow-right-s-line"></i>
                </a>
            </li>
        </ul>
    </nav>
</div>

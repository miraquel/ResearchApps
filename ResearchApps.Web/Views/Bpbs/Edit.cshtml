@model ResearchApps.Service.Vm.BpbVm

@{
    ViewBag.Title = "Edit BPB";
    ViewBag.pTitle = $"Edit BPB {Model.Header.BpbId}";
    Layout = "_Layout";
    
    // Serialize lines for Alpine.js
    var linesJson = System.Text.Json.JsonSerializer.Serialize(Model.Lines.Select(l => new {
        bpbLineId = l.BpbLineId,
        bpbId = l.BpbId,
        bpbRecId = l.BpbRecId,
        itemId = l.ItemId,
        itemName = l.ItemName ?? "",
        unitName = l.UnitName ?? "",
        whId = l.WhId,
        whName = l.WhName ?? "",
        qty = l.Qty,
        prodId = l.ProdId ?? "",
        notes = l.Notes ?? "",
        bpbStatusId = l.BpbStatusId
    }));
    
    // Config object
    var configJson = System.Text.Json.JsonSerializer.Serialize(new {
        recId = Model.Header.RecId,
        bpbId = Model.Header.BpbId,
        bpbDate = Model.Header.BpbDate.ToString("yyyy-MM-dd"),
        refId = Model.Header.RefId ?? "",
        descr = Model.Header.Descr ?? "",
        notes = Model.Header.Notes ?? "",
        bpbStatusId = Model.Header.BpbStatusId
    });
}

<div x-data="bpbEdit(@linesJson, @configJson)" x-init="init()">
    @Html.AntiForgeryToken()
    
    <!-- Header Section -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">
                                BPB Header - @Model.Header.BpbId
                                @Html.Raw(Model.Header.BpbStatusName)
                                <span x-show="isHeaderSaving" x-cloak class="spinner-border spinner-border-sm text-primary ms-2"></span>
                            </h5>
                            <div class="d-flex gap-2">
                                <a href="/Bpbs" class="btn btn-secondary btn-sm">
                                    <i class="ri-arrow-left-line me-1"></i> Back to List
                                </a>
                                @if (!string.IsNullOrEmpty(Model.Header.RefId))
                                {
                                    <a href="/Prods/Details?prodId=@Model.Header.RefId" class="btn btn-info btn-sm">
                                        <i class="ri-external-link-line me-1"></i> View Production
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <form id="headerForm" method="post">
                        <input type="hidden" name="RecId" value="@Model.Header.RecId" />
                        <input type="hidden" name="BpbId" value="@Model.Header.BpbId" />
                        <input type="hidden" name="RefType" value="Production" />
                        <input type="hidden" name="RefId" value="@Model.Header.RefId" />
                        <input type="hidden" name="BpbStatusId" value="@Model.Header.BpbStatusId" />
                        <input type="hidden" name="BpbDate" value="@Model.Header.BpbDate.ToString("yyyy-MM-dd")" />
                        
                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label class="form-label">BPB No</label>
                                <input type="text" class="form-control bg-light" value="@Model.Header.BpbId" readonly />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">BPB Date</label>
                                <input type="text" class="form-control bg-light" value="@Model.Header.BpbDateStr" readonly />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Production ID</label>
                                <input type="text" class="form-control bg-light" value="@Model.Header.RefId" readonly />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Description</label>
                                <input type="text" class="form-control bg-light" value="@Model.Header.Descr" readonly />
                            </div>
                            <div class="col-md-3">
                                <label for="HeaderNotes" class="form-label">Notes</label>
                                <input type="text" 
                                       id="HeaderNotes" 
                                       name="Notes"
                                       class="form-control"
                                       value="@Model.Header.Notes"
                                       maxlength="100" />
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary btn-sm" :disabled="isHeaderSaving">
                            <span x-show="!isHeaderSaving"><i class="ri-save-line me-1"></i> Save Header</span>
                            <span x-show="isHeaderSaving" x-cloak>
                                <span class="spinner-border spinner-border-sm me-1"></span> Saving...
                            </span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Lines Section -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">
                                Line Items
                                <span class="badge bg-secondary" x-text="lines.length + ' items'"></span>
                            </h5>
                            <button type="button" class="btn btn-success btn-sm" @@click="showAddLineModal()">
                                <i class="ri-add-line me-1"></i> Add Item
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Lines Table -->
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40px;">#</th>
                                    <th>Item</th>
                                    <th style="width: 150px;">Warehouse</th>
                                    <th class="text-end" style="width: 100px;">Qty</th>
                                    <th style="width: 80px;">Unit</th>
                                    <th style="width: 150px;">Notes</th>
                                    <th style="width: 100px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <template x-for="(line, index) in lines" :key="line.bpbLineId || index">
                                    <tr>
                                        <td x-text="index + 1"></td>
                                        <td x-text="line.itemName"></td>
                                        <td x-text="line.whName"></td>
                                        <td class="text-end" x-text="formatNumber(line.qty)"></td>
                                        <td x-text="line.unitName"></td>
                                        <td x-text="line.notes"></td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <button type="button" 
                                                        class="btn btn-sm btn-outline-primary"
                                                        @@click="editLine(index)"
                                                        title="Edit">
                                                    <i class="ri-pencil-line"></i>
                                                </button>
                                                <button type="button" 
                                                        class="btn btn-sm btn-outline-danger"
                                                        @@click="confirmDeleteLine(index)"
                                                        title="Delete">
                                                    <i class="ri-delete-bin-line"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                </template>
                                <tr x-show="lines.length === 0">
                                    <td colspan="9" class="text-center text-muted py-4">
                                        <i class="ri-inbox-line fs-3 d-block mb-2"></i>
                                        No line items yet. Click "Add Item" to add materials.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Line Modal -->
    <div class="modal fade" :class="{ 'show d-block': lineModal.show }" tabindex="-1" 
         x-show="lineModal.show" x-cloak
         style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" x-text="lineModal.mode === 'add' ? 'Add Line Item' : 'Edit Line Item'"></h5>
                    <button type="button" class="btn-close" @@click="closeLineModal()" :disabled="lineModal.isSaving"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="lineItemId" class="form-label">Item <span class="text-danger">*</span></label>
                        <select id="lineItemId" class="form-select">
                            <option value="">Select Item</option>
                        </select>
                        <div class="text-danger small" x-show="lineModal.errors.itemId" x-text="lineModal.errors.itemId"></div>
                    </div>
                    <div class="mb-3">
                        <label for="lineWhId" class="form-label">Warehouse <span class="text-danger">*</span></label>
                        <select id="lineWhId" class="form-select">
                            <option value="">Select Warehouse</option>
                        </select>
                        <div class="text-danger small" x-show="lineModal.errors.whId" x-text="lineModal.errors.whId"></div>
                    </div>
                    <div class="mb-3">
                        <label for="lineQty" class="form-label">Quantity <span class="text-danger">*</span></label>
                        <input type="text" id="lineQty" class="form-control text-end"
                               @@input="lineModal.data.qty = parseNumber($event.target.value); checkStock()"
                               :value="formatNumber(lineModal.data.qty)"/>
                        <div class="text-danger small" x-show="lineModal.errors.qty" x-text="lineModal.errors.qty"></div>
                    </div>
                    <div class="mb-3">
                        <label for="lineNotes" class="form-label">Notes</label>
                        <input type="text" id="lineNotes" class="form-control" 
                               x-model="lineModal.data.notes"
                               maxlength="100" />
                    </div>
                    <!-- Stock Check Result -->
                    <div x-show="lineModal.stockCheck" x-cloak>
                        <div class="alert" :class="lineModal.stockCheck?.isAvailable ? (lineModal.stockCheck?.willBeBelowBuffer ? 'alert-warning' : 'alert-success') : 'alert-danger'">
                            <i :class="lineModal.stockCheck?.isAvailable ? 'ri-checkbox-circle-line' : 'ri-error-warning-line'" class="me-1"></i>
                            <span x-text="lineModal.stockCheck?.message"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="closeLineModal()" :disabled="lineModal.isSaving">Cancel</button>
                    <button type="button" class="btn btn-primary" @@click="saveLine()" :disabled="lineModal.isSaving">
                        <span x-show="!lineModal.isSaving">
                            <i class="ri-save-line me-1"></i> Save
                        </span>
                        <span x-show="lineModal.isSaving" x-cloak>
                            <span class="spinner-border spinner-border-sm me-1"></span> Saving...
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Delete Confirmation Modal -->
    <div class="modal fade" :class="{ 'show d-block': deleteModal.show }" tabindex="-1"
         x-show="deleteModal.show" x-cloak
         style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="ri-delete-bin-line me-2"></i>Confirm Delete
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @@click="deleteModal.show = false" :disabled="deleteModal.isDeleting"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this line?</p>
                    <div class="card bg-light" x-show="deleteModal.line">
                        <div class="card-body py-2">
                            <p class="mb-1"><strong>Item:</strong> <span x-text="deleteModal.line?.itemName"></span></p>
                            <p class="mb-1"><strong>Warehouse:</strong> <span x-text="deleteModal.line?.whName"></span></p>
                            <p class="mb-0"><strong>Qty:</strong> <span x-text="formatNumber(deleteModal.line?.qty)"></span></p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="deleteModal.show = false" :disabled="deleteModal.isDeleting">Cancel</button>
                    <button type="button" class="btn btn-danger" @@click="deleteLine()" :disabled="deleteModal.isDeleting">
                        <span x-show="!deleteModal.isDeleting">
                            <i class="ri-delete-bin-line me-1"></i> Delete
                        </span>
                        <span x-show="deleteModal.isDeleting" x-cloak>
                            <span class="spinner-border spinner-border-sm me-1"></span> Deleting...
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/bpbs/bpb-edit.js"></script>
}

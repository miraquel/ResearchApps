<!-- Reusable Notification Modal -->
<div id="notificationModal" 
     class="modal fade" 
     style="display: none;"
     tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg">
            <!-- Icon Section -->
            <div class="text-center pt-4 pb-3">
                <div id="notificationIcon" 
                     class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                     style="width: 80px; height: 80px;">
                    <i id="notificationIconElement" style="font-size: 3.5rem;"></i>
                </div>
                <h4 id="notificationTitle" class="fw-bold mb-0"></h4>
            </div>
            
            <!-- Message Section -->
            <div class="modal-body text-center px-4 pb-4">
                <p id="notificationMessage" class="text-muted mb-0 fs-6"></p>
            </div>
            
            <!-- Action Section -->
            <div class="modal-footer border-0 justify-content-center pb-4">
                <button type="button" 
                        id="notificationButton"
                        class="btn px-5 rounded-pill shadow-sm" 
                        data-bs-dismiss="modal">
                    <i class="ri-check-line me-1"></i> OK
                </button>
            </div>
        </div>
    </div>
</div>

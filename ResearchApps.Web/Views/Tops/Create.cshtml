@model ResearchApps.Service.Vm.TopVm

@{
    ViewBag.Title = "Create TOP";
    ViewBag.pTitle = "Create TOP";
    Layout = "_Layout";
}

<div>
    <div class="card">
        <div class="card-body">
            <form id="top-form" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6">
                        <h5 class="mb-3">TOP Information</h5>

                        <div class="mb-3">
                            <label asp-for="TopName" class="form-label"></label>
                            <input asp-for="TopName" class="form-control" placeholder="Enter TOP name" required />
                            <span asp-validation-for="TopName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TopDay" class="form-label"></label>
                            <input asp-for="TopDay" type="number" min="0" class="form-control" placeholder="Enter number of days" required />
                            <span asp-validation-for="TopDay" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="ri-save-line align-bottom me-1"></i> Create
                    </button>
                    <a asp-action="Index" class="btn btn-soft-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@model ResearchApps.Service.Vm.Common.PagedListVm<ResearchApps.Service.Vm.SalesPriceVm>

<table class="table table-bordered table-hover align-middle mb-0" style="width: 100%;">
    <thead class="table-light">
    <tr>
        <th class="sortable-header" style="width: 80px; cursor: pointer;"
            @@click="sort('RecId')" data-column="RecId">
            <div class="d-flex align-items-center justify-content-center">
                <span>ID</span>
                <template x-if="sortBy === 'RecId'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="min-width: 160px; cursor: pointer;"
            @@click="sort('ItemName')" data-column="ItemName">
            <div class="d-flex align-items-center">
                <span>Item Name</span>
                <template x-if="sortBy === 'ItemName'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="min-width: 160px; cursor: pointer;"
            @@click="sort('CustomerName')" data-column="CustomerName">
            <div class="d-flex align-items-center">
                <span>Customer Name</span>
                <template x-if="sortBy === 'CustomerName'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="width: 120px; cursor: pointer;"
            @@click="sort('StartDate')" data-column="StartDate">
            <div class="d-flex align-items-center justify-content-center">
                <span>Start Date</span>
                <template x-if="sortBy === 'StartDate'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="width: 120px; cursor: pointer;"
            @@click="sort('EndDate')" data-column="EndDate">
            <div class="d-flex align-items-center justify-content-center">
                <span>End Date</span>
                <template x-if="sortBy === 'EndDate'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="width: 140px; cursor: pointer;"
            @@click="sort('SalesPrice')" data-column="SalesPrice">
            <div class="d-flex align-items-center justify-content-end">
                <span>Sales Price</span>
                <template x-if="sortBy === 'SalesPrice'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="sortable-header" style="width: 120px; cursor: pointer;"
            @@click="sort('StatusId')" data-column="StatusId">
            <div class="d-flex align-items-center justify-content-center">
                <span>Status</span>
                <template x-if="sortBy === 'StatusId'">
                    <i :class="sortAsc ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'" class="ms-1"></i>
                </template>
            </div>
        </th>
        <th class="text-center" style="width: 80px;">Actions</th>
    </tr>
    </thead>
    <tbody id="sales-price-table-body">
        @await Html.PartialAsync("_Partials/_SalesPriceListPartial", Model)
    </tbody>
    <tfoot class="table-light">
    <tr>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="ID..."
                   x-model="filters.RecId" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search item..."
                   x-model="filters.ItemName" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Search customer..."
                   x-model="filters.CustomerName" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <input type="date" class="form-control form-control-sm"
                   x-model="filters.StartDate" @@change="fetchList()">
        </td>
        <td>
            <input type="date" class="form-control form-control-sm"
                   x-model="filters.EndDate" @@change="fetchList()">
        </td>
        <td>
            <input type="text" class="form-control form-control-sm" placeholder="Price..."
                   x-model="filters.SalesPrice" @@input.debounce.500ms="fetchList()">
        </td>
        <td>
            <select class="form-select form-select-sm" x-model="filters.StatusId" @@change="fetchList()">
                <option value="">All Status</option>
                <option value="1">Active</option>
                <option value="0">Inactive</option>
            </select>
        </td>
        <td class="text-center">
            <button type="button" class="btn btn-sm btn-outline-secondary"
                    @@click="clearFilters()" title="Clear All Filters">
                <i class="ri-filter-off-line"></i>
            </button>
        </td>
    </tr>
    </tfoot>
</table>

<div class="mt-3">
    @await Html.PartialAsync("_Partials/_SalesPricePaginationPartial", Model)
</div>

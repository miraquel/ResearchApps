@model ResearchApps.Service.Vm.Common.PagedListVm<ResearchApps.Service.Vm.SalesPriceVm>

@if (Model.Items.Any())
{
    foreach (var item in Model.Items)
    {
        <tr>
            <td class="text-center">@item.RecId</td>
            <td><strong>@item.ItemName</strong></td>
            <td>@item.CustomerName</td>
            <td class="text-center">@item.StartDate.ToString("dd MMM yyyy")</td>
            <td class="text-center">@item.EndDate.ToString("dd MMM yyyy")</td>
            <td class="text-end">@item.SalesPriceValue.ToString("N0")</td>
            <td class="text-center">
                @Html.Raw(item.StatusName)
            </td>
            <td class="text-center">
                <div class="dropdown d-inline-block">
                    <button class="btn btn-soft-secondary btn-sm dropdown" type="button"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="ri-more-fill align-middle"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a href="/SalesPrices/Details/@item.RecId" class="dropdown-item">
                                <i class="ri-eye-fill align-bottom me-2 text-muted"></i> View
                            </a>
                        </li>
                        <li>
                            <a href="/SalesPrices/Edit/@item.RecId" class="dropdown-item">
                                <i class="ri-pencil-fill align-bottom me-2 text-muted"></i> Edit
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a href="/SalesPrices/Delete/@item.RecId" class="dropdown-item text-danger">
                                <i class="ri-delete-bin-fill align-bottom me-2"></i> Delete
                            </a>
                        </li>
                    </ul>
                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="8" class="text-center text-muted py-4">
            <i class="ri-inbox-line fs-2"></i>
            <p class="mb-0 mt-2">No sales prices found</p>
        </td>
    </tr>
}

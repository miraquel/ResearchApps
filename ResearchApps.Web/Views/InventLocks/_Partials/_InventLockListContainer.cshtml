@model IEnumerable<ResearchApps.Service.Vm.InventLockVm>
@{
    var selectedYear = ViewBag.SelectedYear ?? DateTime.Now.Year;
    var canClose = ViewBag.CanClose ?? false;
    var canOpen = ViewBag.CanOpen ?? false;
}

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle mb-0">
        <thead class="table-light">
        <tr>
            <th class="text-center" style="width: 80px;">Month</th>
            <th style="min-width: 150px;">Period</th>
            <th class="text-center" style="width: 120px;">Status</th>
            <th style="min-width: 150px;">Modified By</th>
            <th class="text-center" style="width: 180px;">Modified Date</th>
            <th class="text-center" style="width: 100px;">Actions</th>
        </tr>
        </thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center py-5">
                    <div class="text-muted">
                        <i class="ri-calendar-line fs-1"></i>
                        <p class="mb-2 mt-3">No inventory lock records found for @selectedYear</p>
                        <p class="small text-secondary">Records are created automatically when the closing process runs.</p>
                    </div>
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.OrderBy(x => x.Month))
            {
                <tr>
                    <td class="text-center fw-semibold">@item.Month.ToString("00")</td>
                    <td>
                        <div class="d-flex align-items-center">
                            <i class="ri-calendar-2-line text-muted me-2"></i>
                            @item.Period
                        </div>
                    </td>
                    <td class="text-center">
                        @Html.Raw(item.StatusBadge)
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ModifiedBy))
                        {
                            <div class="d-flex align-items-center">
                                <i class="ri-user-line text-muted me-2"></i>
                                @item.ModifiedBy
                            </div>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="text-center">
                        @if (item.ModifiedDate != default)
                        {
                            @item.ModifiedDate.ToString("dd MMM yyyy HH:mm")
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="text-center">
                        @switch (item.Lock)
                        {
                            case true when canOpen:
                                <button type="button" 
                                        class="btn btn-soft-success btn-sm" 
                                        title="Unlock Period"
                                        onclick="window.dispatchEvent(new CustomEvent('open-unlock-modal', { detail: { recId: @item.RecId, year: @item.Year, month: @item.Month, period: '@item.Period' } }))">
                                    <i class="ri-lock-unlock-line"></i> Unlock
                                </button>
                                break;
                            case false when canClose:
                                <span class="badge bg-light text-muted">
                                    <i class="ri-check-line me-1"></i>Open
                                </span>
                                break;
                            default:
                                <span class="text-muted">-</span>
                                break;
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<!-- Summary Stats -->
@if (Model.Any())
{
    var totalLocked = Model.Count(x => x.Lock);
    var totalOpen = Model.Count(x => !x.Lock);
    
    <div class="mt-3 pt-3 border-top">
        <div class="row text-center">
            <div class="col-md-4">
                <div class="d-flex align-items-center justify-content-center">
                    <i class="ri-calendar-check-line text-primary fs-4 me-2"></i>
                    <div class="text-start">
                        <div class="fw-semibold">@Model.Count()</div>
                        <small class="text-muted">Total Periods</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="d-flex align-items-center justify-content-center">
                    <i class="ri-lock-line text-danger fs-4 me-2"></i>
                    <div class="text-start">
                        <div class="fw-semibold text-danger">@totalLocked</div>
                        <small class="text-muted">Closed</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="d-flex align-items-center justify-content-center">
                    <i class="ri-lock-unlock-line text-success fs-4 me-2"></i>
                    <div class="text-start">
                        <div class="fw-semibold text-success">@totalOpen</div>
                        <small class="text-muted">Open</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

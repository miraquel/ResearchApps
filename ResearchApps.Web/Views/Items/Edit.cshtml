@model ResearchApps.Service.Vm.ItemVm

@{
    ViewBag.Title = "Edit Item";
    ViewBag.pTitle = $"Edit Item: {Model.ItemName}";
    Layout = "_Layout";
}

@* Alpine.js component for item edit form *@
<div x-data="itemEdit({ 
        itemTypeId: @Model.ItemTypeId, 
        itemTypeName: '@Model.ItemTypeName', 
        itemDeptId: @Model.ItemDeptId, 
        itemDeptName: '@Model.ItemDeptName', 
        itemGroup01Id: @Model.ItemGroup01Id, 
        itemGroup01Name: '@Model.ItemGroup01Name', 
        itemGroup02Id: @Model.ItemGroup02Id, 
        itemGroup02Name: '@Model.ItemGroup02Name', 
        unitId: @Model.UnitId, 
        unitName: '@Model.UnitName',
        whId: @Model.WhId,
        whName: '@Model.WhName'
    })" x-cloak>
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Edit Item - @Model.ItemName</h5>
                </div>
                <div class="card-body">
                    <form id="item-form" asp-action="Edit" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        
                        <input type="hidden" asp-for="ItemId" />
                        <input type="hidden" asp-for="CreatedDate" />
                        <input type="hidden" asp-for="CreatedBy" />
                        <input type="hidden" asp-for="ModifiedDate" />
                        <input type="hidden" asp-for="ModifiedBy" />

                        <div class="row">
                            @* Basic information section *@
                            <div class="col-md-6">
                                <h5 class="mb-3">Basic Information</h5>
                        
                        <div class="mb-3">
                            <label asp-for="ItemName" class="form-label"></label>
                            <input asp-for="ItemName" class="form-control" required />
                            <span asp-validation-for="ItemName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ItemTypeId" class="form-label"></label>
                            <select asp-for="ItemTypeId" 
                                    id="itemTypeSelect"
                                    x-ref="itemTypeSelect"
                                    class="form-select" 
                                    data-tomselect
                                    data-url="/api/ItemTypes/cbo"
                                    required>
                                <option value="">-- Select Item Type --</option>
                            </select>
                            <span asp-validation-for="ItemTypeId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ItemDeptId" class="form-label"></label>
                            <select asp-for="ItemDeptId" 
                                    id="itemDeptSelect"
                                    x-ref="itemDeptSelect"
                                    class="form-select" 
                                    data-tomselect
                                    data-url="/api/ItemDepts/cbo"
                                    required>
                                <option value="">-- Select Department --</option>
                            </select>
                            <span asp-validation-for="ItemDeptId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ItemGroup01Id" class="form-label"></label>
                            <select asp-for="ItemGroup01Id" 
                                    id="itemGroup01Select"
                                    x-ref="itemGroup01Select"
                                    class="form-select" 
                                    data-tomselect
                                    data-url="/api/ItemGroup01s/Cbo">
                                <option value="">-- Select Item Group 01 --</option>
                            </select>
                            <span asp-validation-for="ItemGroup01Id" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ItemGroup02Id" class="form-label"></label>
                            <select asp-for="ItemGroup02Id" 
                                    id="itemGroup02Select"
                                    x-ref="itemGroup02Select"
                                    class="form-select" 
                                    data-tomselect
                                    data-url="/api/ItemGroup02s/Cbo">
                                <option value="">-- Select Item Group 02 --</option>
                            </select>
                            <span asp-validation-for="ItemGroup02Id" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="UnitId" class="form-label"></label>
                            <select asp-for="UnitId" 
                                    id="unitSelect"
                                    x-ref="unitSelect"
                                    class="form-select" 
                                    data-tomselect
                                    data-url="/api/Units/cbo"
                                    required>
                                <option value="">-- Select Unit --</option>
                            </select>
                                <span asp-validation-for="UnitId" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="WhId" class="form-label">Warehouse</label>
                                <select asp-for="WhId" 
                                        id="warehouseSelect"
                                        x-ref="warehouseSelect"
                                        class="form-select" 
                                        data-tomselect
                                        data-url="/api/Warehouses/cbo"
                                        required>
                                    <option value="">-- Select Warehouse --</option>
                                </select>
                                <span asp-validation-for="WhId" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="BufferStock" class="form-label"></label>
                                <input asp-for="BufferStock" class="form-control" 
                                       x-mask:dynamic="$money($input, '.', ',')" 
                                       placeholder="0.00" />
                                <span asp-validation-for="BufferStock" class="text-danger"></span>
                            </div>
                        </div>

                        @* Pricing and status section *@
                        <div class="col-md-6">
                            <h5 class="mb-3">Pricing & Status</h5>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="PurchasePrice" class="form-label"></label>
                                        <input asp-for="PurchasePrice" class="form-control" 
                                               x-mask:dynamic="$money($input, '.', ',')" 
                                               placeholder="0.00" />
                                        <span asp-validation-for="PurchasePrice" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="SalesPrice" class="form-label"></label>
                                        <input asp-for="SalesPrice" class="form-control" 
                                               x-mask:dynamic="$money($input, '.', ',')" 
                                               placeholder="0.00" />
                                        <span asp-validation-for="SalesPrice" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="CostPrice" class="form-label"></label>
                                <input asp-for="CostPrice" class="form-control" 
                                       x-mask:dynamic="$money($input, '.', ',')" 
                                       placeholder="0.00" />
                                <span asp-validation-for="CostPrice" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Image" class="form-label"></label>
                                <input type="file" 
                                       id="imageUpload"
                                       name="imageUpload"
                                       class="form-control" 
                                       accept="image/*"
                                       @@change="handleImageUpload($event)" />
                                <input type="hidden" asp-for="Image" />
                                <span asp-validation-for="Image" class="text-danger"></span>
                                <div class="mt-2" x-cloak>
                                    <template x-if="imagePreview || '@Model.Image'">
                                        <div>
                                            <img :src="imagePreview || '/images/items/@Model.Image'" alt="Item Image" class="img-thumbnail" style="max-width: 200px; max-height: 200px;" />
                                            <button type="button" class="btn btn-sm btn-danger mt-2" @@click="clearImage()">Remove Image</button>
                                        </div>
                                    </template>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Notes" class="form-label"></label>
                                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Notes" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="StatusId" class="form-label"></label>
                                <select asp-for="StatusId" class="form-select">
                                    <option value="1">Active</option>
                                    <option value="0">Inactive</option>
                                </select>
                                <span asp-validation-for="StatusId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-primary"
                                data-confirm
                                data-confirm-modal="saveModal"
                                data-confirm-form="#item-form"
                                data-confirm-validate="true"
                                data-confirm-title="Confirm Update"
                                data-confirm-message="Are you sure you want to update this item?">
                            <i class="ri-save-line align-bottom me-1"></i> Save Changes
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.ItemId" class="btn btn-soft-secondary">Cancel</a>
                    </div>
                </form>
            </div>
                </div>
            </div>
        </div>
</div>

@section scripts {
    <script src="~/js/items/item-edit.js"></script>
}


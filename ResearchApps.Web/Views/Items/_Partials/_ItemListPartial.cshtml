@model ResearchApps.Service.Vm.Common.PagedListVm<ResearchApps.Service.Vm.ItemVm>

@if (Model.Items.Any())
{
    foreach (var item in Model.Items)
    {
        <tr>
            <td class="text-center">@item.ItemId</td>
            <td><strong>@item.ItemName</strong></td>
            <td class="text-center">@(item.ItemTypeName ?? "-")</td>
            <td class="text-center">@(item.ItemDeptName ?? "-")</td>
            <td class="text-center">@(item.ItemGroup01Name ?? "-")</td>
            <td class="text-center">@(item.ItemGroup02Name ?? "-")</td>
            <td class="text-center">@(item.UnitName ?? "-")</td>
            <td class="text-end">@item.BufferStock.ToString("N2")</td>
            <td class="text-center">@Html.Raw(item.StatusName)</td>
            <td class="text-center">
                @* Actions dropdown *@
                <div class="dropdown d-inline-block">
                    <button class="btn btn-soft-secondary btn-sm dropdown" type="button" 
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="ri-more-fill align-middle"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a href="/Items/Details/@item.ItemId" class="dropdown-item">
                                <i class="ri-eye-fill align-bottom me-2 text-muted"></i> View
                            </a>
                        </li>
                        <li>
                            <a href="/Items/Edit/@item.ItemId" class="dropdown-item">
                                <i class="ri-pencil-fill align-bottom me-2 text-muted"></i> Edit
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a href="/Items/Delete/@item.ItemId" class="dropdown-item text-danger">
                                <i class="ri-delete-bin-fill align-bottom me-2"></i> Delete
                            </a>
                        </li>
                    </ul>
                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="10" class="text-center text-muted py-4">
            <i class="ri-inbox-line fs-2"></i>
            <p class="mb-0 mt-2">No items found</p>
        </td>
    </tr>
}

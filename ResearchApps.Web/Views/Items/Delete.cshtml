@model ResearchApps.Service.Vm.ItemVm

@{
    ViewBag.Title = "Delete Item";
    ViewBag.pTitle = $"Delete Item: {Model.ItemName}";
    Layout = "_Layout";
}

@Html.AntiForgeryToken()

<div class="card">
    <div class="card-header">
        <div class="row">
            <div class="col d-flex justify-content-between align-items-center">
                <ul class="nav nav-tabs-custom rounded card-header-tabs border-bottom-0" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" data-bs-toggle="tab" href="#overview">Overview</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" data-bs-toggle="tab" href="#log">Log</a>
                    </li>
                </ul>
                <div class="position-absolute top-0 end-0">
                    <a asp-action="Details" asp-route-id="@Model.ItemId" class="btn btn-sm btn-secondary me-2">
                        <i class="ri-arrow-left-line"></i> Cancel
                    </a>
                    <button type="button" class="btn btn-sm btn-danger"
                            data-confirm
                            data-confirm-modal="deleteModal"
                            data-confirm-form="#delete-item-form"
                            data-confirm-title="Confirm Delete"
                            data-confirm-message="Are you sure you want to delete this item? This action cannot be undone.">
                        <i class="ri-delete-bin-line"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body">
        <form asp-action="Delete" method="post" id="delete-item-form">
            <input type="hidden" asp-for="ItemId" />
        </form>
        
        <div class="alert alert-danger mb-4">
            <i class="ri-error-warning-line me-2"></i>
            <strong>Warning:</strong> You are about to delete this item. This action cannot be undone.
        </div>
        
        <div class="tab-content">
            <div class="tab-pane active" id="overview" role="tabpanel">
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ItemId)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.ItemId)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ItemName)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.ItemName)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ItemTypeName)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.ItemTypeName)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ItemDeptName)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.ItemDeptName)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ItemGroup01Name)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.ItemGroup01Name)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ItemGroup02Name)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.ItemGroup02Name)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.UnitName)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.UnitName)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.StatusName)</strong></div>
                    <div class="col-9">@Html.Raw(Model.StatusName)</div>
                </div>
            </div>
            <div class="tab-pane" id="log" role="tabpanel">
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.CreatedDate)</strong></div>
                    <div class="col-9">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm:ss")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.CreatedBy)</strong></div>
                    <div class="col-9">@Html.DisplayFor(m => m.CreatedBy)</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ModifiedDate)</strong></div>
                    <div class="col-9">@Model.ModifiedDate.ToString("dd MMM yyyy HH:mm:ss")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-3"><strong>@Html.DisplayNameFor(m => m.ModifiedBy)</strong></div>
                    <div class="col-9">@Model.ModifiedBy</div>
                </div>
            </div>
        </div>
    </div>
</div>

@model ResearchApps.Service.Vm.PoVm

@{
    ViewBag.Title = $"Purchase Order - {Model.Header.PoId}";
    ViewBag.pTitle = $"Purchase Order - {Model.Header.PoId}";
    Layout = "_Layout";
    var isCreator = Model.Header.CreatedBy == User.Identity?.Name;
    const bool showWorkflow = true;
}

<div x-data="{...poDetails('@Model.Header.PoId', @Model.Header.RecId), workflow: createWorkflowComponent({recId: @Model.Header.RecId, refId: '@Model.Header.PoId', baseUrl: '/Pos'}), showWorkflow: @(showWorkflow ? "true" : "false")}" x-init="init()">
    @Html.AntiForgeryToken()

    <div class="card">
        <div class="card-header">
            <div class="row">
                <div class="col d-flex justify-content-between align-items-end">
                    <ul class="nav nav-tabs-custom rounded card-header-tabs border-bottom-0" role="tablist">
                        <li class="nav-item" role="presentation">
                            <a class="nav-link active" data-bs-toggle="tab" href="#overview" role="tab">Overview</a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a class="nav-link" data-bs-toggle="tab" href="#lines" role="tab">Lines</a>
                        </li>
                        <li class="nav-item" role="presentation" x-show="showWorkflow">
                            <a class="nav-link" data-bs-toggle="tab" href="#workflow" role="tab">Workflow</a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a class="nav-link" data-bs-toggle="tab" href="#log" role="tab">Log</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-1 align-self-center">
                        <div id="workflow-buttons-container"
                             hx-get="/Pos/WorkflowButtons/@Model.Header.RecId"
                             hx-target="this"
                             hx-swap="innerHTML"
                             hx-trigger="workflowRefresh from:body">
                            @await Html.PartialAsync("_Partials/_WorkflowButtons", Model.Header)
                        </div>
                            
                        @if (Model.Header.PoStatusId == 0 && isCreator)
                        {
                            <a href="/Pos/Edit/@Model.Header.RecId" class="btn btn-sm btn-success">
                                <i class="ri-edit-line me-1"></i>Edit
                            </a>
                            <a href="/Pos/Delete/@Model.Header.RecId" class="btn btn-sm btn-danger">
                                <i class="ri-delete-bin-line me-1"></i>Delete
                            </a>
                        }
                        <a href="/Pos" class="btn btn-sm btn-secondary">
                            <i class="ri-arrow-left-line me-1"></i>Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="tab-content">
                <!-- Overview Tab -->
                <div class="tab-pane active" id="overview" role="tabpanel">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless mb-0">
                                <tbody>
                                <tr>
                                    <th width="40%">PO ID:</th>
                                    <td><strong>@Model.Header.PoId</strong></td>
                                </tr>
                                <tr>
                                    <th>PO Date:</th>
                                    <td>@Model.Header.PoDate.ToString("dd MMM yyyy")</td>
                                </tr>
                                <tr>
                                    <th>Supplier:</th>
                                    <td>@Model.Header.SupplierName</td>
                                </tr>
                                <tr>
                                    <th>Total Amount:</th>
                                    <td><strong>@((Model.Header.Total).ToString("N0"))</strong></td>
                                </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless mb-0">
                                <tbody>
                                <tr>
                                    <th width="40%">Status:</th>
                                    <td><span id="po-status-badge">@Html.Raw(Model.Header.PoStatusName)</span></td>
                                </tr>
                                <tr>
                                    <th>Notes</th>
                                    <td>@(Model.Header.Notes)</td>
                                </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Lines Tab -->
                <div class="tab-pane" id="lines" role="tabpanel">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0">Purchase Order Lines</h6>
                        <div class="d-flex gap-2 align-items-center">
                            <div id="linesLoadingIndicator" class="htmx-indicator d-flex align-items-center text-muted">
                                <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <small>Loading...</small>
                            </div>
                            <button type="button" 
                                    class="btn btn-sm btn-soft-secondary" 
                                    hx-get="@Url.Action("DetailsLinesPartial", "Pos", new { id = Model.Header.RecId })"
                                    hx-target="#linesContent"
                                    hx-swap="innerHTML"
                                    hx-indicator="#linesLoadingIndicator"
                                    title="Refresh Lines">
                                <i class="ri-refresh-line"></i> Refresh
                            </button>
                        </div>
                    </div>
                    <div id="linesContent"
                         hx-get="@Url.Action("DetailsLinesPartial", "Pos", new { id = Model.Header.RecId })"
                         hx-trigger="load, refreshLines from:body"
                         hx-swap="innerHTML"
                         hx-indicator="#linesLoadingIndicator">
                    </div>
                </div>

                <!-- Workflow Tab -->
                <div class="tab-pane" id="workflow" role="tabpanel" x-show="showWorkflow">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0">Workflow History</h6>
                        <div class="d-flex gap-2 align-items-center">
                            <div id="workflowLoadingIndicator" class="htmx-indicator d-flex align-items-center text-muted">
                                <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <small>Loading...</small>
                            </div>
                            <button type="button" 
                                    class="btn btn-sm btn-soft-secondary" 
                                    hx-get="@Url.Action("WorkflowHistory", "Pos", new { refId = Model.Header.PoId, wfFormId = 3 })"
                                    hx-target="#workflowContent"
                                    hx-swap="innerHTML"
                                    hx-indicator="#workflowLoadingIndicator"
                                    title="Refresh Workflow History">
                                <i class="ri-refresh-line"></i> Refresh
                            </button>
                        </div>
                    </div>
                    <div id="workflowContent"
                         hx-get="@Url.Action("WorkflowHistory", "Pos", new { refId = Model.Header.PoId, wfFormId = 3 })"
                         hx-trigger="load, refreshWorkflow from:body"
                         hx-swap="innerHTML"
                         hx-indicator="#workflowLoadingIndicator">
                    </div>
                </div>

                <!-- Log Tab -->
                <div class="tab-pane" id="log" role="tabpanel">
                    <div class="table-responsive">
                        <table class="table table-borderless mb-0">
                            <tbody>
                            <tr>
                                <th width="20%">Created By:</th>
                                <td>@Model.Header.CreatedBy</td>
                            </tr>
                            <tr>
                                <th>Created Date:</th>
                                <td>@Model.Header.CreatedDate.ToString("dd MMM yyyy HH:mm:ss")</td>
                            </tr>
                            <tr>
                                <th>Last Modified By:</th>
                                <td>@Model.Header.ModifiedBy</td>
                            </tr>
                            <tr>
                                <th>Last Modified Date:</th>
                                <td>@Model.Header.ModifiedDate.ToString("dd MMM yyyy HH:mm:ss")</td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_Partials/_WorkflowModal", Model.Header.PoId)
    @await Html.PartialAsync("_Partials/_PoLineDetailModal")
</div>

@section scripts {
    <script src="~/js/components/workflow-component.js"></script>
    <script src="~/js/pos/po-details.js"></script>
    <script>
        // Pass lines data to Alpine component camelCase
        window.poLinesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Lines ?? [], new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

        // Join PO notification group for real-time updates
        document.addEventListener('DOMContentLoaded', function() {
            WorkflowNotificationManager.joinEntityGroup('po', '@Model.Header.PoId');
        });

        // Handle PO status changes — immediately disable buttons, then refresh just the buttons partial
        document.addEventListener('workflow:statusChanged', function(e) {
            var notification = e.detail;
            if (notification.entityId === '@Model.Header.PoId' && notification.type.startsWith('po')) {
                document.querySelectorAll('#workflow-buttons-container button').forEach(function(b) { b.disabled = true; });
                htmx.trigger(document.body, 'workflowRefresh');
            }
        });
    </script>
}

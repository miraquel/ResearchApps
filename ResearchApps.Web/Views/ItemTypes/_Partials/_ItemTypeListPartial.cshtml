@model ResearchApps.Service.Vm.Common.PagedListVm<ResearchApps.Service.Vm.ItemTypeVm>

@if (Model.Items.Any())
{
    foreach (var item in Model.Items)
    {
        <tr>
            <td class="text-center">@item.ItemTypeId</td>
            <td><strong>@item.ItemTypeName</strong></td>
            <td class="text-center">
                @if (item.StatusId == 1)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-secondary">Inactive</span>
                }
            </td>
            <td class="text-center">
                @* Actions dropdown *@
                <div class="dropdown d-inline-block">
                    <button class="btn btn-soft-secondary btn-sm dropdown" type="button"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="ri-more-fill align-middle"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a href="/ItemTypes/Details/@item.ItemTypeId" class="dropdown-item">
                                <i class="ri-eye-fill align-bottom me-2 text-muted"></i> View
                            </a>
                        </li>
                        <li>
                            <a href="/ItemTypes/Edit/@item.ItemTypeId" class="dropdown-item">
                                <i class="ri-pencil-fill align-bottom me-2 text-muted"></i> Edit
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a href="/ItemTypes/Delete/@item.ItemTypeId" class="dropdown-item text-danger">
                                <i class="ri-delete-bin-fill align-bottom me-2"></i> Delete
                            </a>
                        </li>
                    </ul>
                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="4" class="text-center text-muted py-4">
            <i class="ri-inbox-line fs-2"></i>
            <p class="mb-0 mt-2">No item types found</p>
        </td>
    </tr>
}

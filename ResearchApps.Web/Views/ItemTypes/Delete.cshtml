@model ResearchApps.Service.Vm.ItemTypeVm

@{
    ViewBag.Title = "Delete Item Type";
    ViewBag.pTitle = "Delete Item Type";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-lg-12">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">
                    <i class="ri-alert-line"></i> Confirm Delete
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-warning" role="alert">
                    <i class="ri-error-warning-line me-2"></i>
                    Are you sure you want to delete this item type? This action cannot be undone.
                </div>
                
                <dl class="row">
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.ItemTypeId)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.ItemTypeId)</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.ItemTypeName)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.ItemTypeName)</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.StatusName)</dt>
                    <dd class="col-sm-9">
                        @if (Model.StatusId == 1)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </dd>
                </dl>
                
                <form asp-action="Delete" asp-route-id="@Model.ItemTypeId" method="post" id="delete-itemtype-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ItemTypeId" />
                </form>
                <div class="form-group mt-4">
                    <button type="button" class="btn btn-danger"
                            data-confirm
                            data-confirm-modal="deleteModal"
                            data-confirm-form="#delete-itemtype-form"
                            data-confirm-title="Confirm Delete"
                            data-confirm-message="Are you sure you want to delete this item type? This action cannot be undone.">
                        <i class="ri-delete-bin-line"></i> Delete
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.ItemTypeId" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>

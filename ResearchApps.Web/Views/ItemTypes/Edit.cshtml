@model ResearchApps.Service.Vm.ItemTypeVm

@{
    ViewBag.Title = "Edit Item Type";
    ViewBag.pTitle = $"Edit Item Type: {Model.ItemTypeName}";
    Layout = "_Layout";
}

<div class="card">
    <div class="card-body">
        <form id="itemtype-form" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <input type="hidden" asp-for="ItemTypeId" />
            <input type="hidden" asp-for="StatusId" />
            <input type="hidden" asp-for="CreatedDate" />
            <input type="hidden" asp-for="CreatedBy" />

            <div class="row">
                <div class="col-md-6">
                    <h5 class="mb-3">Item Type Information</h5>
                    
                    <div class="mb-3">
                        <label asp-for="ItemTypeName" class="form-label"></label>
                        <input asp-for="ItemTypeName" class="form-control" required />
                        <span asp-validation-for="ItemTypeName" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="ri-save-line align-bottom me-1"></i> Save Changes
                </button>
                <a asp-action="Details" asp-route-id="@Model.ItemTypeId" class="btn btn-soft-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>


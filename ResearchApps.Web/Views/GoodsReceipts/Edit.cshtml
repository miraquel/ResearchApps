@model ResearchApps.Service.Vm.GoodsReceiptVm

@{
    ViewBag.Title = "Edit Goods Receipt";
    ViewBag.pTitle = $"Edit Goods Receipt No. {Model.Header.GrId}";
    Layout = "_Layout";
    
    // Serialize lines for Alpine.js with camelCase
    var linesJson = System.Text.Json.JsonSerializer.Serialize(Model.Lines.Select(l => new {
        recId = l.RecId,
        grLineId = l.GrLineId,
        grRecId = l.GrRecId,
        poLineId = l.PoLineId,
        itemId = l.ItemId,
        itemName = l.ItemName,
        description = l.Description ?? "",
        qtyPo = l.QtyPo,
        qty = l.Qty,
        unitId = l.UnitId,
        unitName = l.UnitName,
        price = l.Price,
        amount = l.Amount,
        notes = l.Notes ?? "",
        createdDate = l.CreatedDate,
        createdBy = l.CreatedBy,
        modifiedDate = l.ModifiedDate,
        modifiedBy = l.ModifiedBy
    }));
    
    // Config object for grEdit component
    var configJson = System.Text.Json.JsonSerializer.Serialize(new {
        recId = Model.Header.RecId,
        grId = Model.Header.GrId,
        grDate = Model.Header.GrDate.ToString("yyyy-MM-dd"),
        supplierId = Model.Header.SupplierId,
        supplierName = Model.Header.SupplierName,
        refNo = Model.Header.RefNo ?? "",
        notes = Model.Header.Notes ?? ""
    });
}

<div x-data="grEdit(@linesJson, @configJson)" x-init="init()">
    @Html.AntiForgeryToken()
    
    <!-- Header Section -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">
                                GR Header
                                <span class="badge bg-@(Model.Header.GrStatusId == 0 ? "warning" : "success")">
                                    @Model.Header.GrStatusName
                                </span>
                                <span x-show="isHeaderSaving" x-cloak class="spinner-border spinner-border-sm text-primary ms-2"></span>
                            </h5>
                            <div class="d-flex gap-2 align-items-center">
                                <a href="/GoodsReceipts" class="btn btn-secondary btn-sm">
                                    <i class="ri-arrow-left-line me-1"></i> Back to List
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <form id="grForm" method="post">
                        <input type="hidden" name="RecId" value="@Model.Header.RecId" />
                        <input type="hidden" name="GrId" value="@Model.Header.GrId" />
                        <input type="hidden" name="GrStatusId" value="@Model.Header.GrStatusId" />
                        <input type="hidden" name="CreatedDate" value="@Model.Header.CreatedDate.ToString("o")" />
                        <input type="hidden" name="CreatedBy" value="@Model.Header.CreatedBy" />
                        
                        <div class="row">
                            <!-- Left Column -->
                            <div class="col-md-4">
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label class="form-label">GR No</label>
                                            <input type="text" class="form-control bg-light" value="@Model.Header.GrId" readonly />
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label class="form-label">Supplier <span class="text-danger">*</span></label>
                                            <select id="Header_SupplierId" 
                                                    name="SupplierId"
                                                    x-ref="supplierSelect"
                                                    data-tomselect
                                                    data-url="/api/Suppliers/cbo"
                                                    required>
                                                <option value="">Select Supplier</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Middle Column -->
                            <div class="col-md-4">
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label class="form-label">GR Date <span class="text-danger">*</span></label>
                                            <div class="input-group">
                                                <input type="text" 
                                                       class="form-control" 
                                                       id="Header_GrDate"
                                                       name="GrDate"
                                                       x-ref="grDatePicker"
                                                       data-flatpickr
                                                       required />
                                                <span class="input-group-text"><i class="ri-calendar-line"></i></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label class="form-label">Reference No (Optional)</label>
                                            <input type="text" 
                                                   name="RefNo"
                                                   class="form-control"
                                                   value="@Model.Header.RefNo"
                                                   placeholder="Enter reference number"
                                                   maxlength="50" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Right Column -->
                            <div class="col-md-4">
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label class="form-label">Notes (Optional)</label>
                                            <textarea name="Notes" 
                                                      class="form-control" 
                                                      rows="2"
                                                      x-model="header.notes">@Model.Header.Notes</textarea>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="card bg-light mb-0">
                                            <div class="card-body py-2 px-3">
                                                <table class="table table-borderless table-sm mb-0">
                                                    <tr>
                                                        <td class="fw-semibold">Subtotal:</td>
                                                        <td class="text-end">@Model.Header.SubTotal.ToString("N0")</td>
                                                    </tr>
                                                    <tr>
                                                        <td class="fw-semibold">PPN (11%):</td>
                                                        <td class="text-end">@Model.Header.Ppn.ToString("N0")</td>
                                                    </tr>
                                                    <tr class="border-top">
                                                        <td class="fw-bold fs-6">Total:</td>
                                                        <td class="text-end fw-bold text-primary fs-6">@Model.Header.Total.ToString("N0")</td>
                                                    </tr>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mt-3">
                            <div class="col-12 d-flex gap-2">
                                <button type="submit" 
                                        class="btn btn-primary"
                                        :disabled="isHeaderSaving"
                                        @@click.prevent="saveHeader()">
                                    <span x-show="!isHeaderSaving">
                                        <i class="ri-save-line me-1"></i> Save Header
                                    </span>
                                    <span x-show="isHeaderSaving" x-cloak>
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                        Saving...
                                    </span>
                                </button>
                                <a href="/GoodsReceipts/Details/@Model.Header.RecId" class="btn btn-info">
                                    <i class="ri-eye-line me-1"></i> View Details
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Lines Section -->
    <div class="row mt-3">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">
                                GR Lines
                                <span x-show="lineModal.isSaving" x-cloak class="spinner-border spinner-border-sm text-primary ms-2"></span>
                            </h5>
                            <button type="button" class="btn btn-sm btn-success" @@click="showAddLineModal()">
                                <i class="ri-add-line me-1"></i> Add Line
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 50px;">#</th>
                                    <th style="min-width: 200px;">Item</th>
                                    <th class="text-end" style="width: 100px;">Qty</th>
                                    <th class="text-center" style="width: 80px;">Unit</th>
                                    <th class="text-end" style="width: 120px;">Price</th>
                                    <th class="text-end" style="width: 130px;">Amount</th>
                                    <th style="width: 150px;">Notes</th>
                                    <th class="text-center" style="width: 100px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <template x-if="lines.length === 0">
                                    <tr>
                                        <td colspan="8" class="text-center text-muted py-4">
                                            <i class="ri-inbox-line fs-3 d-block mb-2"></i>
                                            No lines added yet. Click "Add Line" to start.
                                        </td>
                                    </tr>
                                </template>
                                <template x-for="(line, index) in lines" :key="line.grLineId || index">
                                    <tr>
                                        <td class="text-center" x-text="index + 1"></td>
                                        <td x-text="line.itemName"></td>
                                        <td class="text-end" x-text="formatNumber(line.qty)"></td>
                                        <td class="text-center" x-text="line.unitName"></td>
                                        <td class="text-end" x-text="formatNumber(line.price)"></td>
                                        <td class="text-end" x-text="formatNumber(line.amount)"></td>
                                        <td x-text="line.notes || '-'"></td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-info" @@click="editLine(index)" title="Edit">
                                                <i class="ri-edit-line"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-danger" @@click="confirmDeleteLine(index)" title="Delete">
                                                <i class="ri-delete-bin-line"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </template>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Add/Edit Line Modal -->
    <div class="modal fade" 
         :class="{ 'show d-block': lineModal.show }"
         x-show="lineModal.show"
         x-cloak
         tabindex="-1"
         @@click.self="closeLineModal()"
         @@keydown.escape.window="closeLineModal()">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="ri-file-list-3-line me-2"></i>
                        <span x-text="lineModal.mode === 'add' ? 'Add Line' : 'Edit Line'"></span>
                    </h5>
                    <button type="button" class="btn-close" @@click="closeLineModal()"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label">PO Line <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="text" 
                                       class="form-control bg-light" 
                                       :class="{ 'is-invalid': lineModal.errors.poLineId }"
                                       x-model="lineModal.data.poDisplayText" 
                                       readonly 
                                       placeholder="Click button to select PO line" />
                                <button type="button" 
                                        class="btn btn-primary" 
                                        @@click="openPoLineSelector()">
                                    <i class="ri-search-line me-1"></i> Select PO
                                </button>
                            </div>
                            <div class="invalid-feedback" x-show="lineModal.errors.poLineId" x-text="lineModal.errors.poLineId"></div>
                            <small class="text-muted">Item, Unit, and Price will be auto-filled from PO Line</small>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label">Item</label>
                            <input type="text" 
                                   class="form-control bg-light" 
                                   x-model="lineModal.data.itemName" 
                                   readonly 
                                   placeholder="Will be auto-filled from PO Line" />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Qty <span class="text-danger">*</span></label>
                            <input type="text" 
                                   class="form-control text-end" 
                                   inputmode="numeric"
                                   x-mask:dynamic="$money($input, '.', ',')"
                                   x-model="lineModal.data.qty"
                                   :class="{ 'is-invalid': lineModal.errors.qty }" />
                            <div class="invalid-feedback" x-show="lineModal.errors.qty" x-text="lineModal.errors.qty"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Unit</label>
                            <input type="text" 
                                   class="form-control bg-light" 
                                   x-model="lineModal.data.unitName"
                                   readonly 
                                   placeholder="From PO Line" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Warehouse <span class="text-danger">*</span></label>
                            <select class="form-select" x-model="lineModal.data.whId" required>
                                <option value="1">RM (Raw Material)</option>
                                <option value="2">TL (Toll)</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label">Price</label>
                            <input type="text" 
                                   class="form-control text-end bg-light"
                                   :value="formatNumber(lineModal.data.price)"
                                   readonly 
                                   placeholder="From PO Line" />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label">Notes (Optional)</label>
                            <textarea class="form-control" 
                                      rows="2"
                                      x-model="lineModal.data.notes"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="closeLineModal()" :disabled="lineModal.isSaving">
                        Cancel
                    </button>
                    <button type="button" 
                            class="btn btn-primary" 
                            :disabled="lineModal.isSaving"
                            @@click="saveLine()">
                        <span x-show="!lineModal.isSaving">
                            <i class="ri-save-line me-1"></i>
                            <span x-text="lineModal.mode === 'add' ? 'Add Line' : 'Update Line'"></span>
                        </span>
                        <span x-show="lineModal.isSaving" x-cloak>
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            Saving...
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show" x-show="lineModal.show" x-cloak></div>
    
    <!-- Delete Confirmation Modal -->
    <div class="modal fade" 
         :class="{ 'show d-block': deleteModal.show }"
         x-show="deleteModal.show"
         x-cloak
         tabindex="-1"
         @@click.self="deleteModal.show = false"
         @@keydown.escape.window="deleteModal.show = false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">
                        <i class="ri-delete-bin-line me-2"></i>Confirm Delete
                    </h5>
                    <button type="button" class="btn-close" @@click="deleteModal.show = false"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this line?</p>
                    <p class="fw-bold" x-text="deleteModal.line?.itemName"></p>
                    <p class="text-muted mb-0">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="deleteModal.show = false" :disabled="deleteModal.isDeleting">
                        Cancel
                    </button>
                    <button type="button" 
                            class="btn btn-danger" 
                            :disabled="deleteModal.isDeleting"
                            @@click="deleteLine()">
                        <span x-show="!deleteModal.isDeleting">
                            <i class="ri-delete-bin-line me-1"></i> Delete
                        </span>
                        <span x-show="deleteModal.isDeleting" x-cloak>
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            Deleting...
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show" x-show="deleteModal.show" x-cloak></div>
    
    <!-- PO Line Selector Modal -->
    <div class="modal fade" 
         :class="{ 'show d-block': poLineSelector.show }" 
         :style="poLineSelector.show ? 'background: rgba(0,0,0,0.5);' : ''"
         x-show="poLineSelector.show" 
         x-cloak
         tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    
                    <h5 class="modal-title">
                        <i class="ri-file-list-line text-primary me-2"></i>Select PO Line
                    </h5>
                    <button type="button" class="btn-close" @@click="closePoLineSelector()"></button>
                </div>
                <div class="modal-body">
                    <!-- Filters -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label small">PO Number</label>
                            <input type="text" 
                                   class="form-control form-control-sm" 
                                   x-model="poLineSelector.filters.poId"
                                   @@keyup.enter="searchPoLines()"
                                   placeholder="Enter PO number" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Item Name</label>
                            <input type="text" 
                                   class="form-control form-control-sm" 
                                   x-model="poLineSelector.filters.itemName"
                                   @@keyup.enter="searchPoLines()"
                                   placeholder="Enter item name" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small">&nbsp;</label>
                            <button type="button" 
                                    class="btn btn-primary btn-sm w-100" 
                                    @@click="searchPoLines()">
                                <i class="ri-search-line"></i> Search
                            </button>
                        </div>
                    </div>

                    <!-- Loading -->
                    <div x-show="poLineSelector.isLoading" class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted mt-2">Loading PO lines...</p>
                    </div>

                    <!-- Table -->
                    <div x-show="!poLineSelector.isLoading" class="table-responsive">
                        <table class="table table-hover table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>PO Number</th>
                                    <th>Item</th>
                                    <th class="text-end">Ordered</th>
                                    <th class="text-end">Outstanding</th>
                                    <th class="text-end">Price</th>
                                    <th>Unit</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <template x-for="po in poLineSelector.items" :key="po.poLineId">
                                    <tr>
                                        <td x-text="po.poId"></td>
                                        <td x-text="po.itemName"></td>
                                        <td class="text-end" x-text="formatNumber(po.qtyPo)"></td>
                                        <td class="text-end text-primary fw-bold" x-text="formatNumber(po.qtyOs)"></td>
                                        <td class="text-end" x-text="formatNumber(po.price)"></td>
                                        <td x-text="po.unitName"></td>
                                        <td class="text-center">
                                            <button type="button" 
                                                    class="btn btn-sm btn-success" 
                                                    @@click="selectPoLine(po)">
                                                <i class="ri-check-line"></i> Select
                                            </button>
                                        </td>
                                    </tr>
                                </template>
                                <tr x-show="poLineSelector.items.length === 0">
                                    <td colspan="7" class="text-center text-muted py-4">
                                        <i class="ri-inbox-line fs-1"></i>
                                        <p class="mb-0">No PO lines found</p>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div x-show="!poLineSelector.isLoading && poLineSelector.totalPages > 1" 
                         class="d-flex justify-content-between align-items-center mt-3">
                        <div class="text-muted small">
                            Showing <span x-text="poLineSelector.items.length"></span> of 
                            <span x-text="poLineSelector.totalCount"></span> items
                        </div>
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item" :class="{ 'disabled': poLineSelector.pageNumber === 1 }">
                                    <button class="page-link" @@click="changePoLinePage(poLineSelector.pageNumber - 1)">
                                        <i class="ri-arrow-left-s-line"></i>
                                    </button>
                                </li>
                                <template x-for="page in poLineSelector.totalPages" :key="page">
                                    <li class="page-item" :class="{ 'active': page === poLineSelector.pageNumber }">
                                        <button class="page-link" @@click="changePoLinePage(page)" x-text="page"></button>
                                    </li>
                                </template>
                                <li class="page-item" :class="{ 'disabled': poLineSelector.pageNumber === poLineSelector.totalPages }">
                                    <button class="page-link" @@click="changePoLinePage(poLineSelector.pageNumber + 1)">
                                        <i class="ri-arrow-right-s-line"></i>
                                    </button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="closePoLineSelector()">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@@section scripts {
    <script src="~/js/goods-receipts/gr-edit.js"></script>
}


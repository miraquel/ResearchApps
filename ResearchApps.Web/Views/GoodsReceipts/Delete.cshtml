@model ResearchApps.Service.Vm.GoodsReceiptHeaderVm

@{
    ViewBag.Title = "Delete Goods Receipt";
    ViewBag.pTitle = $"Delete Goods Receipt No. {Model.GrId}";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-lg-8 offset-lg-2">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">
                    <i class="ri-error-warning-line me-2"></i>Confirm Delete
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-danger mb-4">
                    <i class="ri-error-warning-fill me-2"></i>
                    <strong>Warning!</strong> You are about to delete this Goods Receipt. This action cannot be undone.
                </div>
                
                <h6 class="fw-bold mb-3">Goods Receipt Details:</h6>
                <table class="table table-bordered">
                    <tr>
                        <td class="fw-semibold text-muted" style="width: 200px;">GR No</td>
                        <td>@Model.GrId</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">GR Date</td>
                        <td>@Model.GrDate.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">Supplier</td>
                        <td>@Model.SupplierName</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">Reference No</td>
                        <td>@(string.IsNullOrEmpty(Model.RefNo) ? "-" : Model.RefNo)</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">Status</td>
                        <td>
                            <span class="badge @(Model.GrStatusId == 0 ? "bg-warning" : "bg-success")">
                                @Model.GrStatusName
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">Subtotal</td>
                        <td>@Model.SubTotal.ToString("N0")</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">PPN (11%)</td>
                        <td>@Model.Ppn.ToString("N0")</td>
                    </tr>
                    <tr class="table-warning">
                        <td class="fw-bold">Total</td>
                        <td class="fw-bold text-primary">@Model.Total.ToString("N0")</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold text-muted">Created By</td>
                        <td>@Model.CreatedBy on @Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                </table>
                
                <form asp-action="Delete" asp-route-id="@Model.RecId" method="post" id="delete-goodsreceipt-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="RecId" value="@Model.RecId" />
                </form>
                <div class="d-flex gap-2 mt-4">
                    <button type="button" class="btn btn-danger"
                            data-confirm
                            data-confirm-modal="deleteModal"
                            data-confirm-form="#delete-goodsreceipt-form"
                            data-confirm-title="Confirm Delete"
                            data-confirm-message="Are you sure you want to delete this goods receipt? This action cannot be undone.">
                        <i class="ri-delete-bin-line me-1"></i> Confirm Delete
                    </button>
                    <a href="/GoodsReceipts" class="btn btn-secondary">
                        <i class="ri-arrow-left-line me-1"></i> Cancel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

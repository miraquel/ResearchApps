@model ResearchApps.Service.Vm.WarehouseVm

@{
    ViewBag.Title = "Delete Warehouse";
    ViewBag.pTitle = $"Delete Warehouse {Model.WhId}";
    Layout = "_Layout";
}

<div class="card">
    <div class="card-header">
        <div class="row">
            <div class="col d-flex justify-content-between align-items-center">
                <ul class="nav nav-tabs-custom rounded card-header-tabs border-bottom-0" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" data-bs-toggle="tab" href="#overview">Overview</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" data-bs-toggle="tab" href="#log">Log</a>
                    </li>
                </ul>
                <div class="position-absolute top-0 end-0">
                    <a asp-action="Index" class="btn btn-sm btn-secondary me-2">Cancel</a>
                    <button type="button" class="btn btn-sm btn-danger"
                            data-confirm
                            data-confirm-modal="deleteModal"
                            data-confirm-form="#delete-warehouse-form"
                            data-confirm-title="Confirm Delete"
                            data-confirm-message="Are you sure you want to delete this warehouse? This action cannot be undone.">
                        <i class="ri-delete-bin-line"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body">
        <form asp-action="Delete" method="post" id="delete-warehouse-form">
            <input type="hidden" asp-for="WhId" />
        </form>

        <div class="alert alert-danger mb-4">
            <i class="ri-error-warning-line me-2"></i>
            <strong>Warning:</strong> You are about to delete this warehouse. This action cannot be undone.
        </div>

        <div class="tab-content">
            <div class="tab-pane active" id="overview" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <td class="fw-bold" style="width: 150px;">@Html.DisplayNameFor(m => m.WhId)</td>
                                <td>@Model.WhId</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">@Html.DisplayNameFor(m => m.WhName)</td>
                                <td>@Model.WhName</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">@Html.DisplayNameFor(m => m.StatusName)</td>
                                <td>@Html.Raw(Model.StatusName)</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="tab-pane" id="log" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <td class="fw-bold" style="width: 150px;">@Html.DisplayNameFor(m => m.CreatedDate)</td>
                                <td>@Model.CreatedDate</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">@Html.DisplayNameFor(m => m.CreatedBy)</td>
                                <td>@Model.CreatedBy</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <td class="fw-bold" style="width: 150px;">@Html.DisplayNameFor(m => m.ModifiedDate)</td>
                                <td>@Model.ModifiedDate</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">@Html.DisplayNameFor(m => m.ModifiedBy)</td>
                                <td>@Model.ModifiedBy</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

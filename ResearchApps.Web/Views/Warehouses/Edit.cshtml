@model ResearchApps.Service.Vm.WarehouseVm

@{
    ViewBag.Title = "Edit Warehouse";
    ViewBag.pTitle = $"Edit Warehouse: {Model.WhName}";
    Layout = "_Layout";
}

@* Page header with title and back button *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Edit Warehouse</h2>
    <a asp-action="Index" class="btn btn-soft-secondary">
        <i class="ri-arrow-left-line align-bottom me-1"></i> Back to List
    </a>
</div>

@* Form card *@
<div class="card">
    <div class="card-body">
        <form id="warehouse-form" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="WhId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="WhName" class="form-label"></label>
                        <input asp-for="WhName" class="form-control" placeholder="Enter warehouse name" required />
                        <span asp-validation-for="WhName" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-primary"
                        data-confirm
                        data-confirm-modal="saveWarehouseModal"
                        data-confirm-form="#warehouse-form"
                        data-confirm-validate="true"
                        data-confirm-title="Confirm Save"
                        data-confirm-message="Are you sure you want to save changes to this warehouse?">
                    <i class="ri-save-line align-bottom me-1"></i> Save
                </button>
                <a asp-action="Index" class="btn btn-soft-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

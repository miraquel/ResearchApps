@model ResearchApps.Service.Vm.PhpVm

@{
    ViewBag.Title = "Penerimaan Hasil Produksi Details";
    ViewBag.pTitle = $"PHP No. {Model.Header.PhpId}";
    Layout = "_Layout";
    
    var statusBadgeClass = Model.Header.PhpStatusId switch
    {
        0 => "bg-warning",    // Draft
        1 => "bg-success",    // Active
        2 => "bg-primary",    // Closed
        3 => "bg-danger",     // Cancelled
        _ => "bg-secondary"
    };
}

<div x-data="phpDetails()" x-init="init()">
    @Html.AntiForgeryToken()
    
    <!-- Header Info Card -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <div class="row">
                        <div class="col d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">
                                <span class="badge @statusBadgeClass me-2">@Model.Header.PhpStatusName</span>
                                PHP No: @Model.Header.PhpId
                            </h5>
                            <div class="d-flex gap-2 align-items-center">
                                @if (Model.CanEdit)
                                {
                                    <a href="/Phps/Edit/@Model.Header.RecId" class="btn btn-info btn-sm">
                                        <i class="ri-edit-line me-1"></i> Edit
                                    </a>
                                }
                                @if (Model.CanDelete)
                                {
                                    <button type="button" class="btn btn-danger btn-sm" @@click="showDeleteConfirm = true">
                                        <i class="ri-delete-bin-line me-1"></i> Delete
                                    </button>
                                }
                                <a href="/Phps" class="btn btn-secondary btn-sm">
                                    <i class="ri-arrow-left-line me-1"></i> Back to List
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <!-- Left Column -->
                        <div class="col-md-4">
                            <table class="table table-borderless table-sm mb-0">
                                <tr>
                                    <td class="text-muted" style="width: 140px;">PHP No:</td>
                                    <td class="fw-semibold">@Model.Header.PhpId</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">PHP Date:</td>
                                    <td class="fw-semibold">@Model.Header.PhpDate.ToString("dd MMM yyyy")</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Description:</td>
                                    <td class="fw-semibold">@(string.IsNullOrEmpty(Model.Header.Descr) ? "-" : Model.Header.Descr)</td>
                                </tr>
                            </table>
                        </div>
                        
                        <!-- Middle Column -->
                        <div class="col-md-4">
                            <table class="table table-borderless table-sm mb-0">
                                <tr>
                                    <td class="text-muted" style="width: 140px;">Reference ID:</td>
                                    <td class="fw-semibold">@(string.IsNullOrEmpty(Model.Header.RefId) ? "-" : Model.Header.RefId)</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Status:</td>
                                    <td><span class="badge @statusBadgeClass">@Model.Header.PhpStatusName</span></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Notes:</td>
                                    <td class="fw-semibold">@(string.IsNullOrEmpty(Model.Header.Notes) ? "-" : Model.Header.Notes)</td>
                                </tr>
                            </table>
                        </div>
                        
                        <!-- Right Column - Totals -->
                        <div class="col-md-4">
                            <div class="card bg-light mb-0">
                                <div class="card-body py-3 px-4">
                                    <table class="table table-borderless table-sm mb-0">
                                        <tr class="border-top">
                                            <td class="fw-bold fs-5">Total Amount:</td>
                                            <td class="text-end fw-bold text-primary fs-5">@Model.Header.Amount.ToString("N0")</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Lines Section -->
    <div class="row mt-3">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <ul class="nav nav-tabs card-header-tabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" 
                                    data-bs-toggle="tab" 
                                    data-bs-target="#tab-lines" 
                                    type="button" 
                                    role="tab">
                                <i class="ri-list-unordered me-1"></i> Lines
                                <span class="badge bg-primary ms-1">@Model.Lines.Count()</span>
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" 
                                    data-bs-toggle="tab" 
                                    data-bs-target="#tab-audit" 
                                    type="button" 
                                    role="tab">
                                <i class="ri-history-line me-1"></i> Audit Log
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="card-body">
                    <div class="tab-content">
                        <!-- Lines Tab -->
                        <div class="tab-pane fade show active" id="tab-lines" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-bordered table-striped align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="text-center" style="width: 50px;">#</th>
                                            <th style="min-width: 200px;">Item</th>
                                            <th style="width: 120px;">Warehouse</th>
                                            <th class="text-end" style="width: 100px;">Qty</th>
                                            <th class="text-center" style="width: 80px;">Unit</th>
                                            <th class="text-end" style="width: 120px;">Price</th>
                                            <th style="width: 120px;">Prod ID</th>
                                            <th style="width: 150px;">Notes</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.Lines.Any())
                                        {
                                            var lineIndex = 1;
                                            foreach (var line in Model.Lines)
                                            {
                                                <tr>
                                                    <td class="text-center">@lineIndex</td>
                                                    <td>@line.ItemName</td>
                                                    <td>@line.WhName</td>
                                                    <td class="text-end">@line.Qty.ToString("N0")</td>
                                                    <td class="text-center">@line.UnitName</td>
                                                    <td class="text-end">@line.Price.ToString("N0")</td>
                                                    <td>@(line.ProdId ?? "-")</td>
                                                    <td>@(string.IsNullOrEmpty(line.Notes) ? "-" : line.Notes)</td>
                                                </tr>
                                                lineIndex++;
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="8" class="text-center text-muted py-4">
                                                    <i class="ri-inbox-line fs-3 d-block mb-2"></i>
                                                    No lines found
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        
                        <!-- Audit Tab -->
                        <div class="tab-pane fade" id="tab-audit" role="tabpanel">
                            <table class="table table-borderless table-sm">
                                <tr>
                                    <td class="text-muted" style="width: 150px;">Created By:</td>
                                    <td>@Model.Header.CreatedBy</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Created Date:</td>
                                    <td>@Model.Header.CreatedDate.ToString("dd MMM yyyy HH:mm:ss")</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Modified By:</td>
                                    <td>@Model.Header.ModifiedBy</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Modified Date:</td>
                                    <td>@Model.Header.ModifiedDate.ToString("dd MMM yyyy HH:mm:ss")</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Delete Confirmation Modal -->
    <div class="modal fade" 
         :class="{ 'show d-block': showDeleteConfirm }"
         x-show="showDeleteConfirm"
         x-cloak
         tabindex="-1"
         @@click.self="showDeleteConfirm = false"
         @@keydown.escape.window="showDeleteConfirm = false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="ri-error-warning-line me-2"></i>Confirm Delete
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @@click="showDeleteConfirm = false"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete PHP <strong>@Model.Header.PhpId</strong>?</p>
                    <p class="text-danger mb-0"><small>This action cannot be undone and all lines will be deleted.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="showDeleteConfirm = false">Cancel</button>
                    <form method="post" action="/Phps/Delete/@Model.Header.RecId">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">
                            <i class="ri-delete-bin-line me-1"></i> Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show" x-show="showDeleteConfirm" x-cloak></div>
</div>

@section scripts {
    <script src="~/js/phps/php-details.js"></script>
}

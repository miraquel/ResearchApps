@model ResearchApps.Service.Vm.PhpVm

@{
    ViewBag.Title = "Create Penerimaan Hasil Produksi";
    ViewBag.pTitle = "Create Penerimaan Hasil Produksi";
    Layout = "_Layout";
}

<div x-data="phpCreate()" x-init="init()">
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Create New Penerimaan Hasil Produksi</h5>
                </div>
                <div class="card-body">
                    <form id="php-form" 
                          method="post"
                          action="/Phps/Create">
                        @Html.AntiForgeryToken()
                        
                        <!-- Validation Summary -->
                        <div id="validation-summary" x-show="Object.keys(errors).length > 0" x-cloak>
                            <div class="alert alert-danger">
                                <template x-for="(error, field) in errors" :key="field">
                                    <div x-text="error"></div>
                                </template>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="Header_PhpDate" class="form-label">PHP Date <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <input type="text" 
                                               id="Header_PhpDate" 
                                               name="PhpDate"
                                               class="form-control"
                                               x-ref="phpDatePicker"
                                               data-flatpickr
                                               :class="{ 'is-invalid': errors.PhpDate }"
                                               required />
                                        <span class="input-group-text"><i class="ri-calendar-line"></i></span>
                                    </div>
                                    <div class="invalid-feedback" x-show="errors.PhpDate" x-text="errors.PhpDate"></div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="Header_Descr" class="form-label">Description</label>
                                    <input type="text" 
                                           id="Header_Descr" 
                                           name="Descr"
                                           class="form-control"
                                           placeholder="Enter description"
                                           maxlength="50" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="Header_RefId" class="form-label">Reference ID</label>
                                    <input type="text" 
                                           id="Header_RefId" 
                                           name="RefId"
                                           class="form-control"
                                           placeholder="Enter reference ID"
                                           maxlength="20" />
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label for="Header_Notes" class="form-label">Notes (Optional)</label>
                                    <textarea id="Header_Notes"
                                              name="Notes"
                                              class="form-control" 
                                              rows="3" 
                                              placeholder="Enter notes (optional)"
                                              x-model="header.notes"></textarea>
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-group d-flex gap-2">
                            <button type="submit" 
                                    class="btn btn-primary"
                                    :disabled="isSubmitting"
                                    @@click.prevent="confirmSubmit()">
                                <span x-show="!isSubmitting">
                                    <i class="ri-save-line me-1"></i> Save
                                </span>
                                <span x-show="isSubmitting" x-cloak>
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    Creating...
                                </span>
                            </button>
                            <a href="/Phps" class="btn btn-secondary">
                                <i class="ri-arrow-left-line me-1"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Confirmation Modal -->
    <div class="modal fade" 
         :class="{ 'show d-block': showConfirmModal }"
         x-show="showConfirmModal"
         x-cloak
         tabindex="-1"
         @@click.self="showConfirmModal = false"
         @@keydown.escape.window="showConfirmModal = false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Create</h5>
                    <button type="button" class="btn-close" @@click="showConfirmModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to create this Penerimaan Hasil Produksi?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="showConfirmModal = false">Cancel</button>
                    <button type="button" class="btn btn-primary" @@click="submitForm()">
                        <i class="ri-check-line me-1"></i> Confirm
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show" x-show="showConfirmModal" x-cloak></div>
</div>

@section scripts {
    <script src="~/js/phps/php-create.js"></script>
}

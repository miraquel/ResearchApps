@model ResearchApps.Service.Vm.UnitVm

@{
    ViewBag.Title = "Edit Unit";
    ViewBag.pTitle = $"Edit Unit: {Model.UnitName}";
    Layout = "_Layout";
}

@* Alpine.js component for unit edit form *@
<div x-data="unitEdit(@Model.StatusId)">
    @* Page header with title and back button *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Edit Unit</h2>
        <a asp-action="Index" class="btn btn-soft-secondary">
            <i class="ri-arrow-left-line align-bottom me-1"></i> Back to List
        </a>
    </div>

    @* Form card *@
    <div class="card">
        <div class="card-body">
            <form id="unit-form" asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UnitId" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="UnitName" class="form-label"></label>
                            <input asp-for="UnitName" class="form-control" placeholder="Enter unit name" required />
                            <span asp-validation-for="UnitName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StatusId" class="form-label"></label>
                            <select asp-for="StatusId" id="statusSelect" class="form-control">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="StatusId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-primary"
                            data-confirm
                            data-confirm-modal="saveUnitModal"
                            data-confirm-form="#unit-form"
                            data-confirm-validate="true"
                            data-confirm-title="Confirm Save"
                            data-confirm-message="Are you sure you want to save changes to this unit?">
                        <i class="ri-save-line align-bottom me-1"></i> Save
                    </button>
                    <a asp-action="Index" class="btn btn-soft-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/units/unit-edit.js"></script>
}

